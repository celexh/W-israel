local BarNames = { "HealthBarA", "HealthBarB", "HealthBarC", "HealthBarD" }

local function ColorFix(value)
    if value <= 1 then
        return math.floor((value * 255) + 0.5)
    end
    return math.floor(value + 0.5)
end

local function getRgb(value)
    if not value then
        return nil, nil, nil
    end
    local r = nil
    local g = nil
    local b = nil
    pcall(function()
        r = value.R
        g = value.G
        b = value.B
    end)
    if r == nil and type(value) == "table" then
        r = value[1] or value.r
        g = value[2] or value.g
        b = value[3] or value.b
    end
    r = ColorFix(r)
    g = ColorFix(g)
    b = ColorFix(b)
    if r == nil or g == nil or b == nil then
        return nil, nil, nil
    end
    return r, g, b
end

local function GetGUIrgb(instance)
    local properties = { "Color", "BackgroundColor3", "ImageColor3", "TextColor3" }
    for _, property in ipairs(properties) do
        local r, g, b = getRgb(readProperty(instance, property))
        if r ~= nil then
            return r, g, b, property
        end
    end
    return nil, nil, nil, nil
end

local function isCapturedHealthBarRgb(r, g, b)
    return type(r) == "number"
        and type(g) == "number"
        and type(b) == "number"
        and r <= 15
        and g >= 110
        and g <= 145
        and b >= 240
end

local function readTextValue(instance)
    local value = readProperty(instance, "Text")
    if type(value) == "string" then
        return value
    end
    local textObject = readProperty(instance, "Text")
    value = readProperty(textObject, "Text")
    if type(value) == "string" then
        return value
    end
    value = readProperty(textObject, "Value")
    if type(value) == "string" then
        return value
    end
    return ""
end

local function trimText(text)
    text = tostring(text or "")
    text = string.gsub(text, "^%s+", "")
    text = string.gsub(text, "%s+$", "")
    return text
end

local function playerMatchesHealthBarText(player, text, exactOnly)
    text = string.lower(trimText(text))
    if text == "" or not player then
        return false
    end
    local name = string.lower(tostring(readProperty(player, "Name") or ""))
    local displayName = string.lower(tostring(readProperty(player, "DisplayName") or ""))
    if text == name or (displayName ~= "" and text == displayName) then
        return true
    end
    if exactOnly then
        return false
    end
    if name ~= "" and string.find(text, name, 1, true) then
        return true
    end
    if displayName ~= "" and string.find(text, displayName, 1, true) then
        return true
    end
    if name ~= "" and string.find(name, text, 1, true) then
        return true
    end
    return false
end

local function findPlayerFromHealthBarText(text)
    for _, player in ipairs(Players and Players:GetPlayers() or {}) do
        if player ~= LocalPlayer and playerMatchesHealthBarText(player, text, true) then
            return player
        end
    end
    for _, player in ipairs(Players and Players:GetPlayers() or {}) do
        if player ~= LocalPlayer and playerMatchesHealthBarText(player, text, false) then
            return player
        end
    end
    return nil
end

local function getLocalStatusBars()
    local playerGui = readProperty(LocalPlayer, "PlayerGui")
    local screenGui = readProperty(playerGui, "ScreenGui")
    return readProperty(screenGui, "StatusBars")
end

local function getHealthBar(statusBars, barName)
    local healthBar = readProperty(statusBars, barName)
    if not healthBar then
        return nil
    end
    local bar = readProperty(healthBar, "Bar")
    local r, g, b, colorProperty = GetGUIrgb(bar)
    local text = trimText(readTextValue(healthBar))
    local captured = isCapturedHealthBarRgb(r, g, b)
    return {
        name = barName,
        healthBar = healthBar,
        bar = bar,
        text = text,
        r = r,
        g = g,
        b = b,
        colorProperty = colorProperty,
        captured = captured,
        player = findPlayerFromHealthBarText(text),
    }
end

local function getHealthBarCaptureStateForPlayer(player)
    local statusBars = getLocalStatusBars()
    if not statusBars then
        return nil, "statusbars missing"
    end
    for _, barName in ipairs(BarNames) do
        local entry = getHealthBar(statusBars, barName)
        if entry and playerMatchesHealthBarText(player, entry.text, false) then
            return entry.captured == true, entry
        end
    end
    return nil, "player bar missing"
end

local function isPlayerCapturedForSave(player)
    local guiCaptured, guiInfo = getHealthBarCaptureStateForPlayer(player)
    if guiCaptured ~= nil then
        return guiCaptured
    end
    local statCaptured = getStatsBool(player, "Captured")
    return statCaptured
end

local function getCP() -- get captured player from health bar
    local statusBars = getLocalStatusBars()
    if not statusBars then
        return nil, nil, false
    end

    local seen = 0
    for _, barName in ipairs(BarNames) do
        local entry = getHealthBar(statusBars, barName)
        if entry then
            seen = seen + 1
            if entry.captured and entry.player then
                local character = entry.player.Character
                local root = readProperty(character, "HumanoidRootPart")
                if root then
