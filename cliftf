if HeartbeatSignal then
    local connection = HeartbeatSignal:Connect(function()
        if not state.running then
            return
        end
        local now = tick()
        pcall(updateBeastMovement)
        pcall(updateAutomation, now)
        pcall(refreshStatus, false)
    end)
    table.insert(state.connections, connection)
else
    notify("RunService loop signal unavailable; automation disabled", 4)
end

if PreRenderSignal then
    local connection = PreRenderSignal:Connect(function()
        if not state.running then
            return
        end
        pcall(drawEspOverlay)
    end)
    table.insert(state.connections, connection)
else
    SetLabel(state.labels.esp, "ESP error")
end

ENV.__ftf = function()
    state.running = false
    stopThread("autoDo")
    stopThread("antiCapture")
    reAntiCapture()
    stopThread("saveCaptured")
    stopThread("annoyBeast")
    stopThread("mainLoop")
    stopFlingBeast()
    for _, connection in ipairs(state.connections) do
        Disconnect(connection)
    end
    state.connections = {}
    pcall(function()
        gui.remove_tab(tab_name)
    end)
end

