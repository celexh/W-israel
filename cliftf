local function color4(r, g, b, a)
    a = a == nil and 1 or a
    if Color4 and type(Color4.fromRGBA) == "function" then
        local ok, value = pcall(Color4.fromRGBA, math.floor(r or 255), math.floor(g or 255), math.floor(b or 255), math.floor((a or 1) * 255))
        if ok and value then
            return value
        end
    end
    if Color4 and type(Color4.new) == "function" then
        local ok, value = pcall(Color4.new, (r or 255) / 255, (g or 255) / 255, (b or 255) / 255, a or 1)
        if ok and value then
            return value
        end
    end
    if Color4 and type(Color4.new) == "function" then
        local ok, value = pcall(Color4.new, r or 255, g or 255, b or 255, a or 1)
        if ok and value then
            return value
        end
    end
    return nil
end

