local function getFontDescriptor(size)
    size = tonumber(size) or 13
    if state.fontCache[size] ~= nil then
        return state.fontCache[size] ~= false and state.fontCache[size] or nil
    end
    if type(font) ~= "table" or type(font.get_font_descriptor) ~= "function" then
        state.fontCache[size] = false
        return nil
    end
    for _, name in ipairs({"Comic Sans", "Default", "Inter", "Roboto", "Arial", "Verdana"}) do
        local ok, descriptor = pcall(font.get_font_descriptor, name, size)
        if ok and descriptor then
            state.fontCache[size] = descriptor
            return descriptor
        end
    end
    state.fontCache[size] = false
    return nil
end

local function projectToScreen(target)
    if type(rendering) ~= "table" then
        return nil, false
    end
    local project = rendering.world_to_screen or rendering.worldtoscreen
    if type(project) ~= "function" then
        return nil, false
    end
    local ok, point, visible = pcall(project, target)
    if ok and point then
        return point, visible == true
    end
    return nil, false
end

local function drawText2d(x, y, text, color, size)
    if type(immediate) ~= "table" or type(immediate.text) ~= "function" then
        return false
    end
    local position = vec2(math.floor(x or 0), math.floor(y or 0))
    local descriptor = getFontDescriptor(size or 13)
    if not position or not descriptor then
        return false
    end
    local drawColor = color or EspColors.player
    if not drawColor then
        return false
    end
    local ok, result = pcall(immediate.text, position, tostring(text or ""), descriptor, true, drawColor)
    return ok == true and result ~= false
end

local function drawRect2d(x, y, w, h, color)
    if type(immediate) ~= "table" or type(immediate.rectangle) ~= "function" then
        return false
    end
    local firstCorner = vec2(math.floor((x or 0) + (w or 0)), math.floor((y or 0) + (h or 0)))
    local secondCorner = vec2(math.floor(x or 0), math.floor(y or 0))
    local drawColor = color or EspColors.player
    if not firstCorner or not secondCorner or not drawColor then
        return false
    end
    local ok, result = pcall(immediate.rectangle, firstCorner, secondCorner, 0, false, true, drawColor)
    return ok == true and result ~= false
end

local function httpGet(url)
    if not HttpService or type(HttpService.RequestAsync) ~= "function" then
        return nil
    end
    local ok, response = pcall(function()
        return HttpService:RequestAsync({
            Url = url,
            Method = "GET",
        })
    end)
    if ok and type(response) == "table" and response.Success ~= false and type(response.Body) == "string" then
        return response.Body
    end
    return nil
end

