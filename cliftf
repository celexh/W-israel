    return drawText2d(point.X - 18, point.Y - 16, label, color, 13)
end

local function getComputerEspColorAndLabel(screen)
    local hideHacked = getBool("hide_hacked_pcs")
    local hideErrored = getBool("hide_error_pcs")
    local sourceColor = screen and screen.Color
    local r = sourceColor and sourceColor.R or 13
    local g = sourceColor and sourceColor.G or 105
    local b = sourceColor and sourceColor.B or 172
    if r <= 1 and g <= 1 and b <= 1 then
        r = math.floor((r * 255) + 0.5)
        g = math.floor((g * 255) + 0.5)
        b = math.floor((b * 255) + 0.5)
    else
        r = math.floor(r + 0.5)
        g = math.floor(g + 0.5)
        b = math.floor(b + 0.5)
    end

    local label = "PC Hacked"
    local hidden = false
    if r == 13 and g == 105 and b == 172 then
        label = "PC Hackable"
    elseif r == 196 and g == 40 and b == 28 then
        if hideErrored then
            label = "PC Hackable"
            r, g, b = 13, 105, 172
        else
            label = "PC Errored"
        end
    elseif hideHacked then
        hidden = true
    end

    if hidden then
        return nil, nil
    end
    return label, color4(r, g, b, 1) or EspColors.pc
end

local function drawCharacterEsp()
    local playerEspEnabled = getBool("npc_player_esp")
    local beastEspEnabled = getBool("npc_beast_esp")
    if not playerEspEnabled and not beastEspEnabled then
        return
    end

    local localCharacter = getLocalCharacter()
    local targets = CharacterTargets()
    for _, model in ipairs(targets) do
        local isLocalModel = model == localCharacter or (LocalPlayer and tostring(model.Name) == tostring(LocalPlayer.Name))
        if isFtfCharacterModel(model) and not isLocalModel then
            local isBeast = isBeastModel(model)
            local shouldShow = (isBeast and beastEspEnabled) or ((not isBeast) and playerEspEnabled)
            if shouldShow then
                local root = readProperty(model, "HumanoidRootPart")
                local head = readProperty(model, "Head") or root
                if root and head and head.Position and root.Position then
                    local headTarget = vec3(head.Position.X, head.Position.Y + 0.6, head.Position.Z)
                    local footTarget = vec3(root.Position.X, root.Position.Y - 3.2, root.Position.Z)
                    local headPoint, headVisible = projectToScreen(headTarget or head)
                    local footPoint, footVisible = projectToScreen(footTarget or root)
                    if headVisible and footVisible and headPoint and footPoint then
                        local boxHeight = math.max(18, math.abs(footPoint.Y - headPoint.Y))
                        local boxWidth = math.max(12, math.floor(boxHeight * 0.55))
                        local boxX = math.floor(headPoint.X - (boxWidth / 2))
                        local boxY = math.floor(headPoint.Y)
                        local color = isBeast and EspColors.beast or EspColors.player
                        drawRect2d(boxX, boxY, boxWidth, boxHeight, color)
                        drawText2d(boxX, boxY - 16, tostring(model.Name or "Player"), color, 13)
                    end
                end
            end
        end
    end
end

