local INTERACT_KEY = Enum.KeyCode.E

local function releaseInteractKey()
    pcall(keyrelease, INTERACT_KEY)
end

local function shouldSendInteract()
    return isrbxactive() == true
end

local function restoreSaveCapturedPosition()
    if state.saveCapturedReturnCFrame then
        local root = getLocalRoot()
        if root then
            pcall(function()
                root.CFrame = state.saveCapturedReturnCFrame
            end)
        end
    end
    state.saveCapturedReturnCFrame = nil
    state.saveCapturedTargetUserId = nil
end

local function resetSaveCaptured(restorePosition)
    if state.saveCapturedReleaseAt then
        releaseInteractKey()
    end
    state.saveCapturedReleaseAt = nil
    state.nextSc = 0
    if restorePosition then
        restoreSaveCapturedPosition()
    else
        state.saveCapturedReturnCFrame = nil
        state.saveCapturedTargetUserId = nil
    end
end

local function resetAutoDo()
    if state.autoPuzzkeRelease then
        releaseInteractKey()
    end
    state.autoPuzzlePressed = false
    state.autoPuzzlePending = nil
    state.autoPuzzkeRelease = nil
    state.nextPuzzle = 0
end

local function isAntiCaptureActive()
    return state.threads.antiCapture == true and getBool("anti_capture_toggle") == true
end

local function reAntiCapture()
    if type(state.antiCaptureCollisions) == "table" then
        for part, canCollide in pairs(state.antiCaptureCollisions) do
            if Parent(part) then
                pcall(function()
                    part.CanCollide = canCollide == true
                end)
            end
        end
    end
    state.antiCaptureCollisions = nil
    state.antiCaptureCollisionCharacter = nil
end

local function applyAntiCapture()
    local character = getLocalCharacter()
    if not character then
        reAntiCapture()
        return false
    end

    if state.antiCaptureCollisionCharacter ~= character then
        reAntiCapture()
        state.antiCaptureCollisionCharacter = character
        state.antiCaptureCollisions = {}
    elseif type(state.antiCaptureCollisions) ~= "table" then
        state.antiCaptureCollisions = {}
    end

    local changed = 0
    for _, part in ipairs(character:GetDescendants()) do
        if part and part:IsA("BasePart") then
            if state.antiCaptureCollisions[part] == nil then
                local ok, canCollide = pcall(function()
                    return part.CanCollide
                end)
                if ok then
                    state.antiCaptureCollisions[part] = canCollide == true
                end
            end
            local ok = pcall(function()
                part.CanCollide = false
            end)
            if ok then
                changed = changed + 1
            end
        end
    end
    return changed > 0
end

local function stopThread(id)
    if id == "antiCapture" then
        state.nextAnticapture = 0
        reAntiCapture()
    elseif id == "annoyBeast" then
        state.nextAb = 0
    elseif id == "saveCaptured" then
        resetSaveCaptured(true)
    elseif id == "autoDo" then
        resetAutoDo()
    end
    state.threads[id] = nil
end

local function startAntiCapture()
    state.threads.antiCapture = true
    state.nextAnticapture = 0
end

local function startAnnoyBeast()
    state.threads.annoyBeast = true
    state.nextAb = 0
end

local function startSaveCaptured()
    resetSaveCaptured(false)
    state.threads.saveCaptured = true
end

local function startAutoDo()
    resetAutoDo()
    state.threads.autoDo = true
end

local function updateAntiCapture(now)
    if not isAntiCaptureActive() then
        reAntiCapture()
        return
    end
    if now < (state.nextAnticapture or 0) then
        return
    end
    state.nextAnticapture = now + 0.1

    applyAntiCapture()
end

local function moveRootToPosition(root, targetPosition)
    if not root or not targetPosition then
        return false
    end
    local movedOk = pcall(function()
        root.CFrame = CFrame.new(targetPosition.X, targetPosition.Y, targetPosition.Z)
    end)
    if not movedOk then
        movedOk = pcall(function()
            root.Position = targetPosition
        end)
    end
    return movedOk
end

local function updateAnnoyBeast(now)
    local frontEnabled = getBool("annoy_beast_front_toggle")
    local backEnabled = getBool("annoy_beast_back_toggle")
    if not state.threads.annoyBeast or (not frontEnabled and not backEnabled) then
        return
    end
    if now < (state.nextAb or 0) then
        return
    end
    state.nextAb = now + 0.06

    local root = getLocalRoot()
    local _, beastRoot = getBeast()
    if root and beastRoot and not isLocalPlayerCaptured() and not isLocalPlayerBeastNow() and canLocalPlayerAct() then
        local targetPosition = frontEnabled and getAnnoyBeastFrontPosition(beastRoot) or getAnnoyBeastBackPosition(beastRoot)
        if targetPosition then
            moveRootToPosition(root, targetPosition)
        end
    end
end

local function updateSaveCaptured(now)
    if state.saveCapturedReleaseAt and now >= state.saveCapturedReleaseAt then
        releaseInteractKey()
        state.saveCapturedReleaseAt = nil
    end

    if not state.threads.saveCaptured or not getBool("save_captured_toggle") then
        resetSaveCaptured(true)
        return
    end
    if now < (state.nextSc or 0) then
        return
    end

    local root = getLocalRoot()
    local localCaptured = isLocalPlayerCaptured()
    local localBeast = isLocalPlayerBeastNow()
    local canAct = canLocalPlayerAct()

    if localCaptured or localBeast or not canAct or not root then
        restoreSaveCapturedPosition()
        state.nextSc = now + 0.15
        return
    end

    local targetPlayer, targetRoot = getCapturedPlayerTarget()
    if targetPlayer and targetRoot then
        if state.saveCapturedTargetUserId ~= targetPlayer.UserId or not state.saveCapturedReturnCFrame then
            state.saveCapturedReturnCFrame = root.CFrame
            state.saveCapturedTargetUserId = targetPlayer.UserId
        end

        local targetPosition = getSaveCapturedPosition(targetRoot)
        if not targetPosition then
            state.nextSc = now + 0.15
            return
        end

        if pcall(function()
            root.Position = targetPosition
        end) and shouldSendInteract() and not state.saveCapturedReleaseAt then
            pcall(keypress, INTERACT_KEY)
            state.saveCapturedReleaseAt = now + 0.03
        end

        if not isPlayerCapturedForSave(targetPlayer) then
            restoreSaveCapturedPosition()
            state.nextSc = now + 0.1
        else
            state.nextSc = now + 0.06
        end
    else
        restoreSaveCapturedPosition()
        state.nextSc = now + 0.15
    end
end

local function updateAutoDo(now)
    if state.autoPuzzkeRelease and now >= state.autoPuzzkeRelease then
        releaseInteractKey()
        state.autoPuzzkeRelease = nil
        state.autoPuzzlePressed = true
    end

    if not state.threads.autoDo or not getBool("auto_do_toggle") then
        resetAutoDo()
        return
    end

    if state.autoPuzzlePending and now >= state.autoPuzzlePending then
        state.autoPuzzlePending = nil
        local activeWindow = shouldSendInteract()
        if activeWindow then
            pcall(keypress, INTERACT_KEY)
            state.autoPuzzkeRelease = now + 0.05
        end
    end

    if now < (state.nextPuzzle or 0) then
        return
    end
    state.nextPuzzle = now + 0.1

    local playerGui = readProperty(LocalPlayer, "PlayerGui")
    local screenGui = readProperty(playerGui, "ScreenGui")
    local timingCircle = readProperty(screenGui, "TimingCircle")
    local timingPin = readProperty(timingCircle, "TimingPin")
    local timingBase = readProperty(timingCircle, "TimingBase")
    if not timingCircle
        or not timingPin
        or not timingBase
        or type(memory) ~= "table"
        or type(memory.readu8) ~= "function"
        or type(memory.readf32) ~= "function" then
        state.autoPuzzlePressed = false
        state.autoPuzzlePending = nil
        return
    end

    local circleAddress = readProperty(timingCircle, "Address")
    local pinAddress = readProperty(timingPin, "Address")
    local baseAddress = readProperty(timingBase, "Address")
    if type(circleAddress) ~= "number" or type(pinAddress) ~= "number" or type(baseAddress) ~= "number" then
        state.autoPuzzlePressed = false
        state.autoPuzzlePending = nil
        return
    end

    local ok, readVisibleOk, circleVisible = pcall(memory.readu8, circleAddress + 0x5ad)
    if circleVisible == nil and type(readVisibleOk) == "number" then
        circleVisible = readVisibleOk
    end
    if not ok or (circleVisible ~= 1 and circleVisible ~= true) then
        state.autoPuzzlePressed = false
        state.autoPuzzlePending = nil
        return
    end

    local pinOk, pinReadOk, pinRotation = pcall(memory.readf32, pinAddress + 0x188)
    local baseOk, baseReadOk, baseRotation = pcall(memory.readf32, baseAddress + 0x188)
    if pinRotation == nil and type(pinReadOk) == "number" then
        pinRotation = pinReadOk
    end
    if baseRotation == nil and type(baseReadOk) == "number" then
        baseRotation = baseReadOk
    end
    if not pinOk or not baseOk or type(pinRotation) ~= "number" or type(baseRotation) ~= "number" then
        return
    end

    local diff = math.abs(pinRotation - baseRotation)
    if diff > 180 then
        diff = 360 - diff
    end
    if diff <= 10.5 and not state.autoPuzzlePressed and not state.autoPuzzlePending and not state.autoPuzzkeRelease then
        state.autoPuzzlePending = now + 0.08
    end
end

local function updateAutomation(now)
    pcall(updateAntiCapture, now)
    pcall(updateAnnoyBeast, now)
    pcall(updateSaveCaptured, now)
    pcall(updateAutoDo, now)
end

