local function refreshCCache(force)
    local now = tick()
    if not force and (now - (state.lastCCacheRefresh or 0)) < 2 then
        return state.CCache or {}
    end

    local results = {}
    local seen = {}
    for _, player in ipairs(Players and Players:GetPlayers() or {}) do
        local model = player.Character
        if not model or not isDescendantOf(model, workspace) then
            model = readProperty(workspace, player.Name)
        end
        if model and isValidFtfCharacterTarget(model) and not seen[model] then
            seen[model] = true
            table.insert(results, model)
        end
    end

    state.CCache = results
    state.lastCCacheRefresh = now
    return results
end

local function CharacterTargets()
    local cached = refreshCCache(false)
    local valid = {}
    for _, target in ipairs(cached or {}) do
        if isValidFtfCharacterTarget(target) then
            table.insert(valid, target)
        end
    end
    if #valid > 0 then
        return valid
    end
    return refreshCCache(true)
end

local function CurrentMap(force)
    local now = tick()
    if state.MapRoot then
        if Parent(state.MapRoot) == workspace then
            if not force then
                return state.MapRoot
            end
        else
            state.MapRoot = nil
        end
    end
    if not force and (now - (state.lastComputerCheck or 0)) < 10 then
        return state.MapRoot
    end

    state.lastComputerCheck = now
    if not workspace then
        state.MapRoot = nil
        return nil
    end

    for _, obj in ipairs(workspace:GetChildren()) do
        local computerTable = readProperty(obj, "ComputerTable")
        if computerTable then
            state.MapRoot = obj
            return obj
        end
        for _, child in ipairs(obj:GetChildren()) do
            computerTable = readProperty(child, "ComputerTable")
            if computerTable then
                state.MapRoot = child
                return child
            end
        end
    end

    state.MapRoot = nil
    return nil
end

local function refreshComputerCache(force)
    local now = tick()
    local mapRoot = CurrentMap(force)
    if not force and state.computerCacheScanned and state.computerCacheMap == mapRoot and state.computerCache and (now - (state.lastComputerCacheRefresh or 0)) < 2 then
        return state.computerCache
    end

    local results = {}
    local scanRoot = mapRoot
    if not scanRoot then
        if state.manualMapScanActive then
            return state.computerCache or {}
        end
        state.computerCache = results
        state.computerCacheMap = nil
        state.computerCacheScanned = true
        state.lastComputerCacheRefresh = now
        return results
    end

    if scanRoot.Name == "ComputerTable" then
        local screen = readProperty(scanRoot, "Screen")
        if not (screen and screen:IsA("BasePart")) then
            for _, child in ipairs(scanRoot:GetChildren()) do
                if child and child:IsA("BasePart") then
                    screen = child
                    break
                end
            end
        end
        if screen and screen:IsA("BasePart") then
            table.insert(results, screen)
        end
    end

    for _, obj in ipairs(scanRoot:GetChildren()) do
        if obj and obj.Name == "ComputerTable" then
            local screen = readProperty(obj, "Screen")
            if not (screen and screen:IsA("BasePart")) then
                for _, child in ipairs(obj:GetChildren()) do
                    if child and child:IsA("BasePart") then
                        screen = child
                        break
                    end
                end
            end
            if screen and screen:IsA("BasePart") then
                table.insert(results, screen)
            end
        end
    end

    state.computerCache = results
    state.computerCacheMap = mapRoot
    state.computerCacheScanned = true
    state.lastComputerCacheRefresh = now
    return results
end

local function getComputerTargets()
