    end

    SetLabel(state.labels.status, "Status: " .. tostring(state.statusText or "Ready"))
    SetLabel(state.labels.counts, string.format(
        "Targets: players=%d | beast=%s | PCs=%d | pods=%d | doors=%d",
        #characters,
        beastName,
        #computers,
        #pods,
        #doors
    ))

    local espEnabled = getBool("npc_player_esp") or getBool("npc_beast_esp") or pcEspEnabled or podEspEnabled or doorEspEnabled
    if espEnabled then
        local overlayReady = type(immediate) == "table" and type(rendering) == "table"
        SetLabel(state.labels.esp, overlayReady and "ESP: on" or "ESP: unavailable")
    else
        SetLabel(state.labels.esp, "ESP: off")
    end

end

