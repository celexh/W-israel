local function getFlingOffsets()
    if state.flingOffsets then
        return state.flingOffsets
    end
    if not HttpService then
        return nil
    end
    local response = httpGet("https://imtheo.lol/Offsets/Offsets.json")
    if not response or response == "" then
        return nil
    end
    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(response)
    end)
    if decodeOk and type(decoded) == "table" and type(decoded.Offsets) == "table" then
        state.flingOffsets = decoded.Offsets
        return state.flingOffsets
    end
    return nil
end

local function getPrimitivePointerOffset(part, primitivePositionOffset)
    if not part or not part.Address
        or type(memory) ~= "table"
        or type(memory.read_pointer) ~= "function"
        or type(memory.readf32) ~= "function"
        or type(primitivePositionOffset) ~= "number" then
        return nil
    end
    for offset = 8, 1024, 8 do
        local readPtrSuccess, _, ptrAddress = pcall(memory.read_pointer, part.Address + offset)
        if readPtrSuccess and ptrAddress and ptrAddress > 10000 then
            local readPosSuccess, _, memPosX = pcall(memory.readf32, ptrAddress + primitivePositionOffset)
            if readPosSuccess and type(memPosX) == "number" and math.abs(memPosX - part.Position.X) < 0.1 then
                return offset
            end
        end
    end
    return nil
end

local function stopFlingBeast()
    Disconnect(state.FBConnection)
    state.FBConnection = nil

    local flingState = state.FBState
    if not flingState then
        return
    end

    if flingState.humanoid and flingState.humanoid.Parent
        and flingState.autoRotateOffset
        and flingState.originalAutoRotate ~= nil
        and type(memory) == "table"
        and type(memory.writeu8) == "function" then
        pcall(memory.writeu8, flingState.humanoid.Address + flingState.autoRotateOffset, flingState.originalAutoRotate)
    end
    if flingState.localRoot and flingState.localRoot.Parent then
        local zero = vec3(0, 0, 0)
        if zero then
            pcall(function()
                flingState.localRoot.Velocity = zero
            end)
            pcall(function()
                flingState.localRoot.RotVelocity = zero
            end)
        end
        if flingState.originalCFrame then
            pcall(function()
                flingState.localRoot.CFrame = flingState.originalCFrame
            end)
        end
    end
    if flingState.primitiveAddress and flingState.angVelOffset then
        local targetX = flingState.primitiveAddress + flingState.angVelOffset
        if type(memory) == "table" and type(memory.writef32) == "function" then
            pcall(memory.writef32, targetX, 0)
            pcall(memory.writef32, targetX + 4, 0)
            pcall(memory.writef32, targetX + 8, 0)
        end
    end
    if type(flingState.collisions) == "table" then
        for part, canCollide in pairs(flingState.collisions) do
            if part and part.Parent then
                pcall(function()
                    part.CanCollide = canCollide == true
                end)
            end
        end
    end
    state.FBState = nil
end

local function flingBeast()
    stopFlingBeast()

    local _, beastRoot = getBeast()
    local character = getLocalCharacter()
    local localRoot = readProperty(character, "HumanoidRootPart")
    local humanoid = readProperty(character, "Humanoid")
    if not beastRoot then
        notify("Beast not found", 3)
        return
    end
    if not character or not localRoot or not humanoid or not localRoot.Address or not humanoid.Address then
        notify("Local character not ready", 3)
        return
    end

    local offsets = getFlingOffsets()
    local primitiveOffsets = offsets and offsets.Primitive
    local humanoidOffsets = offsets and offsets.Humanoid
    if type(primitiveOffsets) ~= "table" or type(humanoidOffsets) ~= "table" then
        notify("Offsets unavailable", 3)
        return
    end

    local primitiveOffset = getPrimitivePointerOffset(localRoot, primitiveOffsets.Position)
    if not primitiveOffset then
        notify("Primitive offset not found", 3)
        return
    end
    if type(primitiveOffsets.AssemblyAngularVelocity) ~= "number" or type(humanoidOffsets.AutoRotate) ~= "number" then
        notify("Required offsets unavailable", 3)
        return
    end

    local collisions = {}
    for _, part in ipairs(character:GetDescendants()) do
        if part and part:IsA("BasePart") then
            collisions[part] = part.CanCollide == true
            pcall(function()
                part.CanCollide = false
            end)
        end
    end

    local originalAutoRotate = nil
    if type(memory) == "table" and type(memory.readu8) == "function" then
        local ok, _, value = pcall(memory.readu8, humanoid.Address + humanoidOffsets.AutoRotate)
        if ok then
            originalAutoRotate = value
        end
    end
    if type(memory) == "table" and type(memory.writeu8) == "function" then
        pcall(memory.writeu8, humanoid.Address + humanoidOffsets.AutoRotate, 0)
    end

    local current = localRoot.CFrame
    pcall(function()
        local pos = beastRoot.Position
        localRoot.CFrame = CFrame.new(pos.X, pos.Y, pos.Z)
    end)

    local startedAt = tick()
    local flingSpeed = 120000
    local angVelOffset = primitiveOffsets.AssemblyAngularVelocity
    state.FBState = {
        localRoot = localRoot,
        humanoid = humanoid,
        originalCFrame = current,
        originalAutoRotate = originalAutoRotate,
        autoRotateOffset = humanoidOffsets.AutoRotate,
        collisions = collisions,
        primitiveAddress = nil,
        angVelOffset = angVelOffset,
    }

    if not PreSimulationSignal then
        notify("RunService step signal unavailable", 3)
        stopFlingBeast()
        return
    end

    state.FBConnection = PreSimulationSignal:Connect(function()
        if not state.running or (humanoid.Health or 0) <= 0 or not isDescendantOf(character, workspace) or not Parent(beastRoot) or (tick() - startedAt) >= 2 then
            stopFlingBeast()
            return
        end

        pcall(function()
            local pos = beastRoot.Position
            localRoot.CFrame = CFrame.new(pos.X, pos.Y, pos.Z)
        end)

        if type(memory) ~= "table" or type(memory.read_pointer) ~= "function" or type(memory.writef32) ~= "function" then
            return
        end

        local readOk, _, livePrimitiveAddress = pcall(memory.read_pointer, localRoot.Address + primitiveOffset)
        if not readOk or not livePrimitiveAddress or livePrimitiveAddress <= 10000 then
            return
        end
        if state.FBState then
            state.FBState.primitiveAddress = livePrimitiveAddress
        end

        local targetX = livePrimitiveAddress + angVelOffset
        pcall(function()
            for _ = 1, 2000 do
                memory.writef32(targetX, 0)
                memory.writef32(targetX + 4, flingSpeed)
                memory.writef32(targetX + 8, 0)
            end
        end)
    end)
end

local function setLocalWalkSpeed(speed)
    local humanoid = getLocalHumanoid()
    if not humanoid then
        state.lastAppliedWalkSpeed = nil
        state.lastWalkSpeedWriteAt = 0
        return
    end
    local now = tick()
    if state.lastAppliedWalkSpeed == speed and (now - (state.lastWalkSpeedWriteAt or 0)) < 0.05 then
        return
    end

    humanoid.WalkSpeed = speed

    local _, normalSpeedObj = getStatsValue(LocalPlayer, "NormalWalkSpeed")
    if normalSpeedObj then
        normalSpeedObj.Value = speed
    end

    state.lastAppliedWalkSpeed = speed
    state.lastWalkSpeedWriteAt = now
end

