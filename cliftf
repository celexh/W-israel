local function boolValue(value)
    if value == true then
        return true
    end
    if type(value) == "number" then
        return value ~= 0
    end
    if type(value) == "string" then
        local lowered = string.lower(value)
        return lowered == "true" or lowered == "1"
    end
    return false
end

local function Parent(instance)
    local ok, parent = pcall(function()
        return instance and instance.Parent or nil
    end)
    if ok then
        return parent
    end
    return nil
end

local function readProperty(instance, property)
    local ok, value = pcall(function()
        return instance and instance[property] or nil
    end)
    if ok then
        return value
    end
    return nil
end

local function isDescendantOf(instance, ancestor)
    local current = instance
    while current do
        if current == ancestor then
            return true
        end
        local ok, parent = pcall(function()
            return current.Parent
        end)
        if not ok then
            return false
        end
        current = parent
    end
    return false
end

