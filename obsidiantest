function UI:ZeroPartPhysics(part)
    if not part then
        return
    end

    pcall(function()
        part.Velocity = Vector3.new(0, 0, 0)
    end)
    pcall(function()
        part.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    end)
