function UI:DrawSlider(bucket, control, x, y, w, h)
    local disabled = self:IsControlDisabled(control)
    local compact = control.compact == true or control.Compact == true
    local barY = compact and y or (y + 18)
    if not compact then
        self:CreateText(bucket, self:GetControlLabel(control), x, y, disabled and Theme.textMuted or Theme.text, 14, false)
    end
    self:DrawFastBox(bucket, x, barY, w, 15, Theme.panel, Theme.border, disabled and 0.6 or 1)

    local percent = self.animationState.sliderFill[self:GetControlId(control)] or self:GetSliderPercent(control)
    local fillW = math.floor((w - 2) * percent)
    if fillW > 0 then
        self:CreateSquare(bucket, x + 1, barY + 1, fillW, 13, disabled and Theme.border or Theme.accent, 1, true)
    end
    self:CreateText(bucket, self:GetSliderDisplay(control), x + math.floor(w / 2), barY + 1, disabled and Theme.textMuted or Theme.text, 14, true)

    control._sliderX = x
    control._sliderW = w
end

function UI:DrawDropdown(bucket, control, x, y, w, h)
    local disabled = self:IsControlDisabled(control)
    local label = self:GetControlLabel(control)
    local hasLabel = label ~= ""
    local boxY = hasLabel and (y + 18) or y
    local boxH = 21
    local active = self.expandedDropdown == self:GetControlId(control)

    if hasLabel then
        self:CreateText(bucket, label, x, y, disabled and Theme.textMuted or Theme.text, 14, false)
    end

    local shownValue = self:GetFormattedDropdownValue(control)
    local valueColor = disabled and Theme.textMuted or Theme.text
    if active and self:IsDropdownSearchable(control) then
        local searchText = self.dropdownSearchText[self:GetControlId(control)] or ""
        shownValue = searchText
        if self.searchCursor then
            shownValue = shownValue .. "|"
        end
        if searchText == "" and not self.searchCursor then
            shownValue = "Search..."
            valueColor = Theme.textMuted
        end
    end

    self:DrawFastBox(bucket, x, boxY, w, boxH, Theme.panel, Theme.border, disabled and 0.6 or 1)
    self:CreateText(bucket, self:TruncateText(shownValue, w - 36, 14), x + 8, boxY + 3, valueColor, 14, false)
    self:CreateText(bucket, active and "^" or "v", x + w - 16, boxY + 3, disabled and Theme.textMuted or (active and Theme.text or Theme.textDim), 14, false)
end

function UI:HandleButtonPress(control)
    if not control or self:IsControlDisabled(control) then
        return
    end

    control.flashUntil = tick() + 0.35

    if self:GetControlId(control) == "discord_button" then
        if type(setclipboard) == "function" then
            pcall(setclipboard, "https://discord.gg/Hu7BQwkJ3y")
        end
        self:NotifyPlayer("Discord link copied to clipboard", "Windy", 3)
    end

    self:RunAction(control)
    self:MarkCurrentTabDirty()
end

function UI:HandleControlClick(control)
    if not control then
        return
    end

    if self:IsControlDisabled(control) then
        return
    end

    local controlType = self:GetControlType(control)
    local controlId = self:GetControlId(control)

    if controlType ~= "input" and controlType ~= "textbox" then
        self:BlurActiveTextInput()
    end

    if controlType ~= "dropdown_single" and controlType ~= "dropdown_multi" then
        self.activeDropdownSearch = nil
    end

    if controlType == "toggle" or controlType == "checkbox" then
        local nextValue = not (self:GetControlRawValue(control, false) == true)
        self:SetControlRawValue(control, nextValue)

        if controlId == "ui_animations" then
            self.needsRedraw = true
        end
        if controlId == "no_images" then
            self:MarkShellDirty()
        end

        self:RunAction(control, nextValue)
        self:SaveConfig(controlId == "auto_save_config")

    elseif controlType == "button" then
        self:HandleButtonPress(control)

    elseif controlType == "input" or controlType == "textbox" then
        self:BlurSearch()
        self.expandedDropdown = nil
        self.expandedColorPicker = nil
        self.activeKeybind = nil
        self.activeDropdownSearch = nil
        self.activeTextInput = controlId
        self.searchCursor = true
        self.searchCursorTick = tick()
        self:ZeroSearchKeys()
        self:UpdateRobloxInputCapture()

    elseif controlType == "dropdown_single" or controlType == "dropdown_multi" then
        self.expandedColorPicker = nil
        self.activeKeybind = nil
        self:ToggleDropdown(controlId)
        if self.expandedDropdown == controlId and self:IsDropdownSearchable(control) then
            self.activeDropdownSearch = controlId
            self.dropdownSearchText[controlId] = ""
            self.searchCursor = true
            self.searchCursorTick = tick()
            self:ZeroSearchKeys()
            self:UpdateRobloxInputCapture()
        else
            self.activeDropdownSearch = nil
            self:UpdateRobloxInputCapture()
        end
        return

    elseif controlType == "keybind" then
        self:BlurSearch()
        self:BlurActiveTextInput()
        self.expandedDropdown = nil
        self.expandedColorPicker = nil
        self.activeDropdownSearch = nil
        self.activeKeybind = controlId
        self:ZeroSearchKeys()

    elseif controlType == "colorpicker" then
        self:BlurSearch()
        self:BlurActiveTextInput()
        self.expandedDropdown = nil
        self.activeKeybind = nil
        self.activeDropdownSearch = nil
        if self.expandedColorPicker == controlId then
            self.expandedColorPicker = nil
        else
            self.expandedColorPicker = controlId
        end
        self:UpdateScrollLimit()
        self:MarkCurrentTabDirty()
        return
    end

    self:MarkCurrentTabDirty()
end

function UI:HandleDropdownOption(control, option)
    if not control then
        return
    end

    if self:IsControlDisabled(control) or self:IsDropdownOptionDisabled(control, option) then
        return
    end

    local controlType = self:GetControlType(control)
    local controlId = self:GetControlId(control)

    if controlType == "dropdown_single" then
        self:SetControlRawValue(control, option)
        self.expandedDropdown = nil
        self.activeDropdownSearch = nil

        if controlId == "accent_theme" then
            self:ApplyAccentTheme(self:GetControlRawValue(control, option))
            self:MarkShellDirty()
        end

        self:RunAction(control, self:GetControlRawValue(control, option))

    elseif controlType == "dropdown_multi" then
        control.selected = control.selected or control.Selected or control.value or control.Value or {}
        control.selected[option] = not control.selected[option]
        control.Selected = control.selected
        if control.Value ~= nil then
            control.Value = control.selected
        end

        self:RunAction(control, option, control.selected[option], control.selected)
    end

    self:UpdateScrollLimit()
    self:MarkCurrentTabDirty()
    self:SaveConfig(false)
end

function UI:HandleHotkeys()
    if type(iskeypressed) ~= "function" then
        return
    end

    if self.searchFocused or self.activeTextInput or self.activeDropdownSearch or self.activeKeybind then
        return
    end

    local now = tick()
    if now - self.lastToggleTick < 0.2 then
        return
    end

    local ok, pressed = pcall(iskeypressed, VK_Z)
    if ok and pressed then
        self.uiVisible = not self.uiVisible
        if self.uiVisible then
            self.hiddenCleared = false
            self.contentAlpha = 0.85
            self.contentOffset = 4
            self:MarkShellDirty()
            self:MarkCurrentTabDirty()
        else
            self.draggingWindow = false
            self.draggingResize = false
            self.draggingSlider = false
            self.draggingScroll = false
            self.activeSlider = nil
            self:BlurSearch()
            self:BlurActiveTextInput()
            self.activeDropdownSearch = nil
            self.activeKeybind = nil
            self.expandedDropdown = nil
            self.expandedColorPicker = nil
            self.lastMousePressed = false
            self.lastFrameMouseX = nil
            self.lastFrameMouseY = nil
            self.lastFrameMouseDown = nil
            self:ClearAllBuckets()
            self.hiddenCleared = true
            self.needsRedraw = false
            self.animationsActive = false
        end
        self.lastToggleTick = now
    end
end

function UI:HandleTransientEffects()
    local now = tick()
    local dirty = false

    for _, tabControls in ipairs(self.controls) do
        for _, control in ipairs(tabControls) do
            if self:GetControlType(control) == "button" and control.flashUntil and now >= control.flashUntil then
                control.flashUntil = nil
                dirty = true
            end

            local subButton = self:GetSubButton(control)
            if subButton and subButton.flashUntil and now >= subButton.flashUntil then
                subButton.flashUntil = nil
                dirty = true
            end
        end
    end

    if dirty then
        self:MarkCurrentTabDirty()
    end
end

function UI:HandleInput()
    local mousePos = self:GetMouseLocation()
    local mouseDown = self:IsMousePressed()

    if self.draggingResize and mouseDown then
        local nextWidth = math.clamp(math.floor(mousePos.X - self.window.x + self.resizeOffsetX), self.window.minWidth or 480, self.window.maxWidth or 1000)
        local nextHeight = math.clamp(math.floor(mousePos.Y - self.window.y + self.resizeOffsetY), self.window.minHeight or 360, self.window.maxHeight or 760)

        if self.window.width ~= nextWidth or self.window.height ~= nextHeight then
            self.window.width = nextWidth
            self.window.height = nextHeight
            self:MarkShellDirty()
            for tabIndex = 1, #self.tabDirty do
                self:MarkTabDirty(tabIndex)
            end
        end
    elseif self.draggingResize and not mouseDown then
        self.draggingResize = false
    end

    if self.draggingWindow and mouseDown then
        local nextX = math.floor(mousePos.X - self.dragOffsetX)
        local nextY = math.floor(mousePos.Y - self.dragOffsetY)
        if self.window.x ~= nextX or self.window.y ~= nextY then
            self.window.x = nextX
            self.window.y = nextY
            self:MarkShellDirty()
            self:MarkCurrentTabDirty()
        end
    elseif self.draggingWindow and not mouseDown then
        self.draggingWindow = false
    end

    if self.draggingSlider and self.activeSlider and mouseDown then
        self:SetSliderFromMouse(self.activeSlider, mousePos.X)
    elseif self.draggingSlider and not mouseDown then
        self.draggingSlider = false
        self.activeSlider = nil
    end

    if self.draggingScroll and mouseDown then
        local scrollbarX, scrollbarY, scrollbarW, scrollbarH, _, thumbH = self:GetScrollbarMetrics()
        local available = math.max(1, scrollbarH - thumbH)
        local newThumbY = math.clamp(mousePos.Y - self.scrollDragOffset, scrollbarY, scrollbarY + available)
        self:SetScrollOffset(((newThumbY - scrollbarY) / available) * self.scroll.max)
    elseif self.draggingScroll and not mouseDown then
        self.draggingScroll = false
    end

    if self.draggingAIChatScroll and mouseDown and self.selectedTab == self.aiTabIndex then
        local chatX, chatY, chatW, chatH = self:GetAIChatBounds()
        local viewTop = chatY + 8
        local viewBottom = chatY + chatH - 8
        local trackH = math.max(1, viewBottom - viewTop)
        local viewportH = math.max(1, self.aiChatViewportHeight or trackH)
        local contentH = math.max(viewportH, self.aiChatContentHeight or viewportH)
        local thumbH = math.max(24, math.floor(trackH * (viewportH / contentH)))
        local available = math.max(1, trackH - thumbH)
        local newThumbY = math.clamp(mousePos.Y - (self.aiScrollDragOffset or 0), viewTop, viewTop + available)
        self.aiScrollToLatest = false
        self:SetAIChatScroll(((newThumbY - viewTop) / available) * (self.aiChatScrollMax or 0))
    elseif self.draggingAIChatScroll and (not mouseDown or self.selectedTab ~= self.aiTabIndex) then
        self.draggingAIChatScroll = false
    end

    local hovered = nil
    local clickedHitbox = false
    for index = #self.hitboxes, 1, -1 do
        local hitbox = self.hitboxes[index]
        if mousePos.X >= hitbox.x and mousePos.X <= hitbox.x + hitbox.w and mousePos.Y >= hitbox.y and mousePos.Y <= hitbox.y + hitbox.h then
            hovered = hitbox.id
            if mouseDown and not self.lastMousePressed and hitbox.callback then
                clickedHitbox = true
                hitbox.callback()
            end
            break
        end
    end

    if mouseDown and not self.lastMousePressed and self.searchFocused and not self:IsPointInSearchBox(mousePos) then
        self:BlurSearch()
    end

    if mouseDown and not self.lastMousePressed and not clickedHitbox then
        self:BlurActiveTextInput()
        if self.activeKeybind or self.activeDropdownSearch or self.expandedDropdown or self.expandedColorPicker then
            self.activeKeybind = nil
            self.activeDropdownSearch = nil
            self.expandedDropdown = nil
            self.expandedColorPicker = nil
            self:UpdateScrollLimit()
            self:MarkCurrentTabDirty()
        end

        local canDragWindow = (not self.isBooting and self:IsPointInMainWindow(mousePos))
            or (self.isBooting and self:IsPointInLoadingWindow(mousePos))

        if canDragWindow then
            self.draggingWindow = true
            self.dragOffsetX = mousePos.X - self.window.x
            self.dragOffsetY = mousePos.Y - self.window.y
        end
    end

    if hovered ~= self.hoveredId then
        local previousHovered = self.hoveredId
        local previousIsShell = self:IsShellHitboxId(previousHovered)
        local hoveredIsShell = self:IsShellHitboxId(hovered)
        self.hoveredId = hovered
        if self.isBooting then
            self.needsRedraw = true
        else
            if previousIsShell or hoveredIsShell then
                self:MarkShellDirty()
            end
            if (previousHovered ~= nil and not previousIsShell) or (hovered ~= nil and not hoveredIsShell) then
                self:MarkCurrentTabDirty()
            end
        end
    end

    self.lastMousePressed = mouseDown
end

function UI:RegisterShellHitboxes()
    local wx, wyBase = self:GetRenderWindowPosition()
    local wy = wyBase + self:GetAnimatedWindowYOffset()
    local ww = self.window.width
    local wh = self.window.height
    local sidebarW = self.window.sidebarWidth

    self:RegisterSearchHitbox()

    local tabY = wy + 58
    local tabStep = 40
    local buttonX = wx + 1
    local buttonW = sidebarW - 2
    local buttonH = 40

    for tabIndex, _ in ipairs(self.tabs) do
        local buttonY = tabY + ((tabIndex - 1) * tabStep)

        self:RegisterHitbox("tab_" .. tostring(tabIndex), buttonX, buttonY, buttonW, buttonH, function()
            if self.selectedTab ~= tabIndex then
                self.selectedTab = tabIndex
                self.searchFocused = false
                self.activeTextInput = nil
                self.activeDropdownSearch = nil
                self.activeKeybind = nil
                self:ZeroSearchKeys()
                self:UpdateRobloxInputCapture()
                if tabIndex == 1 then
                    self:RefreshHomeStats(true)
                end
                self.expandedDropdown = nil
                self.scroll.offset = 0
                self:ResetContentAnimation()
                self:UpdateScrollLimit()
                self:MarkShellDirty()
                self:MarkCurrentTabDirty()
            end
        end, 1)
    end

    self:RegisterHitbox("window_drag", wx, wy, ww, 18, function()
        self.draggingWindow = true
        local mousePos = self:GetMouseLocation()
        self.dragOffsetX = mousePos.X - wx
        self.dragOffsetY = mousePos.Y - wy
    end, 1)

    self:RegisterHitbox("window_resize", wx + ww - 22, wy + wh - 22, 22, 22, function()
        self.draggingResize = true
        local mousePos = self:GetMouseLocation()
        self.resizeOffsetX = (self.window.x + self.window.width) - mousePos.X
        self.resizeOffsetY = (self.window.y + self.window.height) - mousePos.Y
    end, 4)
end

function UI:RegisterLoadingHitboxes()
    local loadX, loadY, loadW = self:GetLoadingBounds()

    self:RegisterHitbox("loading_drag", loadX, loadY, loadW, 48, function()
        self.draggingWindow = true
        local mousePos = self:GetMouseLocation()
        self.dragOffsetX = mousePos.X - self.window.x
        self.dragOffsetY = mousePos.Y - self.window.y
    end, 1)
end

function UI:GetControlHeight(control, innerW)
    local controlType = self:GetControlType(control)

    if controlType == "stat" then
        return 21
    elseif controlType == "toggle" or controlType == "checkbox" then
        return 18
    elseif controlType == "button" then
        return 21
    elseif controlType == "slider" then
        return (control.compact or control.Compact) and 15 or 33
    elseif controlType == "dropdown_single" or controlType == "dropdown_multi" then
        local label = self:GetControlLabel(control)
        local baseH = (label ~= "" and 39 or 21)
        local options = self:GetVisibleDropdownOptions(control)
        if self.expandedDropdown == self:GetControlId(control) and options then
            baseH = baseH + math.min(#options, control.maxVisibleDropdownItems or control.MaxVisibleDropdownItems or 8) * 21 + 1
        end
        return baseH
    elseif controlType == "input" or controlType == "textbox" then
        return 39
    elseif controlType == "keybind" then
        return 18
    elseif controlType == "colorpicker" then
        local baseH = 18
        if self.expandedColorPicker == self:GetControlId(control) then
            baseH = baseH + 44
        end
        return baseH
    elseif controlType == "label" then
        if control.wrap or control.DoesWrap then
            return (#self:WrapText(self:GetControlLabel(control), innerW, control.size or 14) * 16) + 4
        end
        return 18
    elseif controlType == "divider" then
        return 6 + (control.marginTop or 0) + (control.marginBottom or 0)
    end

    return 21
end

function UI:BuildObsidianGroups()
    local columns = {
        {},
        {},
    }
    local groupLookup = {
        {},
        {},
    }

    for controlIndex, control in ipairs(self:GetActiveControls()) do
        if self:IsControlVisible(control) then
            local side = control.side or control.column or control.Side or control.Column
            if side == "right" or side == "Right" or side == 2 then
                side = 2
            else
                side = 1
            end

            local groupName = control.group or control.groupbox or control.Group or control.Groupbox
            if not groupName or groupName == "" then
                groupName = self.tabs[self.selectedTab] and self.tabs[self.selectedTab].name or "Groupbox"
            end

            local group = groupLookup[side][groupName]
            if not group then
                group = {
                    name = groupName,
                    iconUrl = control.groupIconUrl or control.iconUrl,
                    iconData = nil,
                    controls = {},
                }
                groupLookup[side][groupName] = group
                table.insert(columns[side], group)
            end

            control._groupOrder = controlIndex
            table.insert(group.controls, control)
        end
    end

    return columns
end

function UI:GetGroupHeight(group, innerW)
    local contentH = 0
    for index, control in ipairs(group.controls) do
        if index > 1 then
            contentH = contentH + 8
        end
        contentH = contentH + self:GetControlHeight(control, innerW)
    end

    return 49 + contentH
end

function UI:DrawObsidianGroupFrame(bucket, group, x, y, w, h)
    if not bucket then
        return
    end

    self:CreateSquare(bucket, x - 1, y - 1, w + 2, h + 2, Theme.dark, 0.65, true)
    self:DrawFastBox(bucket, x, y, w, h, Theme.bg, Theme.border, 1)
    self:CreateLine(bucket, x + 1, y + 34, x + w - 2, y + 34, Theme.border, 1, 1)

    local titleX = x + 12
    if group.iconData then
        local iconObj = self:CreateImage(bucket, group.iconData, x + 6, y + 6, 22, 22, 1)
        if iconObj then
            titleX = x + 36
        end
    end

    self:CreateText(bucket, group.name, titleX, y + 10, Theme.text, 15, false)
end

function UI:DrawObsidianDivider(bucket, control, x, y, w)
    local marginTop = control.marginTop or 0
    local text = control.text or control.Text
    local lineY = y + marginTop + 3

    if not bucket then
        return
    end

    if text and text ~= "" then
        local labelW = self:EstimateTextWidth(text, 14) + 20
        local halfGap = math.floor(labelW / 2)
        local centerX = x + math.floor(w * 0.5)
        self:CreateLine(bucket, x, lineY, centerX - halfGap, lineY, Theme.border, 1, 2)
        self:CreateLine(bucket, centerX + halfGap, lineY, x + w, lineY, Theme.border, 1, 2)
        self:CreateText(bucket, text, centerX, lineY - 7, Theme.textDim, 14, true)
    else
        self:CreateLine(bucket, x, lineY, x + w, lineY, Theme.border, 1, 2)
    end
end

function UI:DrawObsidianInput(bucket, control, x, y, w)
    local disabled = self:IsControlDisabled(control)
    local controlId = self:GetControlId(control)
    local focused = self.activeTextInput == controlId
    local value = tostring(self:GetControlRawValue(control, ""))
    local shownValue = value
    if focused and self.searchCursor then
        shownValue = shownValue .. "|"
    end
    local hasVisibleValue = value ~= "" or focused

    if bucket then
        self:CreateText(bucket, self:GetControlLabel(control), x, y, disabled and Theme.textMuted or Theme.text, 14, false)
        self:DrawFastBox(bucket, x, y + 18, w, 21, Theme.panel, focused and Theme.accent or Theme.border, disabled and 0.6 or 1)
        self:CreateText(bucket, self:TruncateText(hasVisibleValue and shownValue or tostring(control.placeholder or control.Placeholder or ""), w - 16, 14), x + 8, y + 21, hasVisibleValue and Theme.text or Theme.textMuted, 14, false)
    end

    if not disabled then
        self:RegisterHitbox(controlId, x, y + 18, w, 21, function()
            self:HandleControlClick(control)
        end, 2)
    end
end

function UI:DrawKeybind(bucket, control, x, y, w)
    local disabled = self:IsControlDisabled(control)
    local controlId = self:GetControlId(control)
    local active = self.activeKeybind == controlId
    local display = active and "..." or self:GetKeybindDisplay(control)
    local boxW = math.min(90, math.max(44, self:EstimateTextWidth(display, 14) + 18))
    local boxX = x + w - boxW

    if bucket then
        self:CreateText(bucket, self:GetControlLabel(control), x, y + 2, disabled and Theme.textMuted or Theme.text, 14, false)
        self:DrawFastBox(bucket, boxX, y, boxW, 18, Theme.panel, active and Theme.accent or Theme.border, disabled and 0.6 or 1)
        self:CreateText(bucket, self:TruncateText(display, boxW - 10, 14), boxX + math.floor(boxW * 0.5), y + 2, disabled and Theme.textMuted or Theme.textDim, 14, true)
    end
end

function UI:DrawColorPicker(bucket, control, x, y, w, clipBottom)
    local disabled = self:IsControlDisabled(control)
    local controlId = self:GetControlId(control)
    local active = self.expandedColorPicker == controlId
    local swatchSize = 18
    local swatchX = x + w - swatchSize
    local color = self:GetColorValue(control)

    if bucket then
        self:CreateText(bucket, self:GetControlLabel(control), x, y + 2, disabled and Theme.textMuted or Theme.text, 14, false)
        self:DrawFastBox(bucket, swatchX, y, swatchSize, swatchSize, color, active and Theme.accent or Theme.border, disabled and 0.6 or 1)

        if active then
            local menuW = 164
            local menuH = 38
            local menuX = x + w - menuW
            local menuY = y + 24

            if not clipBottom or menuY + menuH <= clipBottom then
                self:DrawFastBox(bucket, menuX, menuY, menuW, menuH, Theme.panel, Theme.border, 1)

                for index, preset in ipairs(ColorPresets) do
                    local presetX = menuX + 7 + ((index - 1) * 19)
                    local presetY = menuY + 10
                    self:DrawFastBox(bucket, presetX, presetY, 14, 14, preset, Theme.border, disabled and 0.6 or 1)
                end
            end
        end
    end
end

function UI:DrawObsidianControl(bucket, control, x, y, w, clipBottom)
    local controlType = self:GetControlType(control)
    local controlId = self:GetControlId(control)

    if controlType == "stat" then
        if bucket then
            self:CreateText(bucket, self:GetControlLabel(control), x, y + 2, Theme.textDim, 14, false)
            self:CreateRightText(bucket, tostring(self:GetControlRawValue(control, "-")), x + w, y + 2, Theme.text, 14)
        end
        return
    elseif controlType == "label" then
        if bucket then
            if control.wrap or control.DoesWrap then
                local lines = self:WrapText(self:GetControlLabel(control), w, control.size or 14)
                for index, line in ipairs(lines) do
                    self:CreateText(bucket, line, x, y + ((index - 1) * 16), Theme.text, control.size or 14, false)
                end
            else
                self:CreateText(bucket, self:TruncateText(self:GetControlLabel(control), w, control.size or 14), x, y + 2, Theme.text, control.size or 14, false)
            end
        end
        return
    elseif controlType == "divider" then
        self:DrawObsidianDivider(bucket, control, x, y, w)
        return
    elseif controlType == "input" or controlType == "textbox" then
        self:DrawObsidianInput(bucket, control, x, y, w)
        return
    elseif controlType == "keybind" then
        self:DrawKeybind(bucket, control, x, y, w)
    elseif controlType == "colorpicker" then
        self:DrawColorPicker(bucket, control, x, y, w, clipBottom)
    end

    if controlType == "toggle" then
        if bucket then
            self:DrawToggle(bucket, control, x, y, w, 18)
        end
    elseif controlType == "checkbox" then
        if bucket then
            self:DrawCheckbox(bucket, control, x, y, w, 18)
        end
    elseif controlType == "button" then
        if bucket then
            local subButton = self:GetSubButton(control)
            if subButton then
                local gap = 9
                local partW = math.floor((w - gap) * 0.5)
                self:DrawButton(bucket, control, x, y, partW, 21)
                self:DrawButton(bucket, subButton, x + partW + gap, y, w - partW - gap, 21)
            else
                self:DrawButton(bucket, control, x, y, w, 21)
            end
        end
    elseif controlType == "slider" then
        if bucket then
            self:DrawSlider(bucket, control, x, y, w, (control.compact or control.Compact) and 15 or 33)
        end
    elseif controlType == "dropdown_single" or controlType == "dropdown_multi" then
        if bucket then
            self:DrawDropdown(bucket, control, x, y, w, self:GetControlHeight(control, w))
        end
    end

    local h = self:GetControlHeight(control, w)
    if controlType == "slider" then
        self:RegisterHitbox(controlId, x, y + ((control.compact or control.Compact) and 0 or 18), w, 15, function()
            self.draggingSlider = true
            self.activeSlider = control
            self:SetSliderFromMouse(control, self:GetMouseLocation().X)
        end, 2)
    elseif controlType ~= "stat" and not self:IsControlDisabled(control) then
        local hitY = y
        local hitH = h
        if controlType == "dropdown_single" or controlType == "dropdown_multi" then
            local hasLabel = self:GetControlLabel(control) ~= ""
            hitY = hasLabel and (y + 18) or y
            hitH = 21
        end
        if controlType == "button" and self:GetSubButton(control) then
            local subButton = self:GetSubButton(control)
            local gap = 9
            local partW = math.floor((w - gap) * 0.5)
            self:RegisterHitbox(controlId, x, hitY, partW, hitH, function()
                self:HandleControlClick(control)
            end, 1)
            if not self:IsControlDisabled(subButton) then
                self:RegisterHitbox(self:GetControlId(subButton), x + partW + gap, hitY, w - partW - gap, hitH, function()
                    self:HandleButtonPress(subButton)
                end, 1)
            end
        else
            self:RegisterHitbox(controlId, x, hitY, w, hitH, function()
                self:HandleControlClick(control)
            end, 1)
        end
    end

    if controlType == "colorpicker" and self.expandedColorPicker == controlId then
        local menuW = 164
        local menuH = 38
        local menuX = x + w - menuW
        local menuY = y + 24
        if not clipBottom or menuY + menuH <= clipBottom then
            for index, preset in ipairs(ColorPresets) do
                local presetX = menuX + 7 + ((index - 1) * 19)
                local presetY = menuY + 10
                self:RegisterHitbox(controlId .. "_color_" .. tostring(index), presetX, presetY, 14, 14, function()
                    self:SetColorValue(control, preset)
                end, 3)
            end
        end
    end

    if controlType == "dropdown_single" or controlType == "dropdown_multi" then
        local expanded = self.expandedDropdown == controlId
        local options = self:GetVisibleDropdownOptions(control)
        if expanded and options then
            local hasLabel = self:GetControlLabel(control) ~= ""
            local listY = (hasLabel and (y + 18) or y) + 22
            local maxItems = math.min(#options, control.maxVisibleDropdownItems or control.MaxVisibleDropdownItems or 8)
            if clipBottom then
                local availableRows = math.max(0, math.floor((clipBottom - listY) / 21))
                maxItems = math.min(maxItems, availableRows)
            end

            if maxItems > 0 then
                local listH = maxItems * 21

                if bucket then
                    self:CreateSquare(bucket, x, listY, w, listH, Theme.panel, 1, true)
                    self:CreateSquare(bucket, x, listY, w, listH, Theme.border, 1, false, 1)
                end

                for optionIndex = 1, maxItems do
                    local option = options[optionIndex]
                    local rowY = listY + ((optionIndex - 1) * 21)
                    local selectedTable = control.selected or control.Selected or control.value or control.Value or {}
                    local selected = controlType == "dropdown_single"
                        and self:GetControlRawValue(control, nil) == option
                        or (selectedTable and selectedTable[option] == true)
                    local disabled = self:IsDropdownOptionDisabled(control, option)
                    local optionId = controlId .. "_opt_" .. tostring(optionIndex)
                    local hovered = self.hoveredId == optionId

                    if bucket then
                        if selected or hovered then
                            self:CreateSquare(bucket, x + 1, rowY + 1, w - 2, 19, selected and Theme.panelAlt or Theme.bg, 1, true)
                        end
                        self:CreateText(bucket, self:TruncateText(self:FormatDropdownListValue(control, option), w - 14, 14), x + 7, rowY + 3, disabled and Theme.textMuted or selected and Theme.text or Theme.textDim, 14, false)
                    end

                    if not disabled then
                        self:RegisterHitbox(optionId, x, rowY, w, 21, function()
                            self:HandleDropdownOption(control, option)
                        end, 3)
                    end
                end
            end
        end
    end
end

function UI:GetAIComposerBounds()
    local x, y, width, height = self:GetContentBounds()
    local pad = 10
    local composerH = 50
    local composerX = x + pad
    local composerY = y + height - composerH - 8
    local composerW = math.max(160, width - (pad * 2))
    local sendW = 76
    local sendX = composerX + composerW - sendW
    local inputX = composerX
    local inputW = math.max(90, composerW - sendW - 8)

    return composerX, composerY, composerW, composerH, inputX, inputW, sendX, sendW
end

function UI:GetAIChatBounds()
    local x, y, width = self:GetContentBounds()
    local pad = 10
    local _, composerY = self:GetAIComposerBounds()
    local settingsPanelH = 0
    local chatX = x + pad
    local chatY = y + 40 + settingsPanelH
    local chatW = math.max(160, width - (pad * 2))
    local chatH = math.max(92, composerY - chatY - 8)

    return chatX, chatY, chatW, chatH
end

function UI:IsMouseInAIChat()
    if self.selectedTab ~= self.aiTabIndex then
        return false
    end

    local mousePos = self:GetMouseLocation()
    local chatX, chatY, chatW, chatH = self:GetAIChatBounds()
    local composerX, composerY, composerW, composerH = self:GetAIComposerBounds()

    return self:IsPointInRect(mousePos, chatX, chatY, chatW, chatH)
        and not self:IsPointInRect(mousePos, composerX, composerY, composerW, composerH)
end

function UI:SetupAIWheelScroll()
    if self.aiWheelConnection then
        return
    end

    local okSignal, signal = pcall(function()
        return UserInputService.InputChanged
    end)

    if not okSignal or not signal then
        return
    end

    local okConnection, connection = pcall(function()
        return signal:Connect(function(input)
            if not self.isRunning or self.isBooting or not self.uiVisible then
                return
            end

            if self.selectedTab ~= self.aiTabIndex then
                return
            end

            if self.draggingResize or self.draggingWindow or self.draggingSlider or self.draggingScroll
                or self.draggingAIChatScroll
                or self.expandedDropdown or self.expandedColorPicker
            then
                return
            end

            local isWheel = false
            pcall(function()
                isWheel = input.UserInputType == Enum.UserInputType.MouseWheel
            end)

            if not isWheel or not self:IsMouseInAIChat() then
                return
            end

            local wheelDelta = 0
            pcall(function()
                if input.Position then
                    wheelDelta = input.Position.Z or 0
                end
            end)
            if wheelDelta == 0 then
                pcall(function()
                    if input.Delta then
                        wheelDelta = input.Delta.Z or 0
                    end
                end)
            end

            if wheelDelta == 0 then
                return
            end

            self.aiScrollToLatest = false
            self:ScrollAIChat(-wheelDelta * 48)
        end)
    end)

    if okConnection and connection then
        self.aiWheelConnection = connection
    end
end

function UI:DrawAIChatTab(bucket)
    local x, y, width = self:GetContentBounds()
    self.scroll.max = 0
    self.scroll.offset = 0

    local pad = 10
    local headerY = y + 6
    local headerH = 24
    local newChatW = 76
    local testW = 52
    local buttonGap = 6
    local newChatX = x + width - pad - newChatW
    local testX = newChatX - buttonGap - testW

    if bucket then
        self:CreateText(bucket, "MatchaMind", x + pad, headerY + 3, Theme.text, 17, false)
        self:DrawFastBox(bucket, testX, headerY, testW, headerH, self.hoveredId == "ai_test_backend" and Theme.panelAlt or Theme.panel, Theme.border, 1)
        self:CreateText(bucket, "Test", testX + math.floor(testW * 0.5), headerY + 5, Theme.textDim, 13, true)
        self:DrawFastBox(bucket, newChatX, headerY, newChatW, headerH, self.hoveredId == "ai_new_chat" and Theme.panelAlt or Theme.panel, Theme.border, 1)
        self:CreateText(bucket, "New Chat", newChatX + math.floor(newChatW * 0.5), headerY + 5, Theme.textDim, 13, true)
    end

    self:RegisterHitbox("ai_test_backend", testX, headerY, testW, headerH, function()
        self:ProbeAIBackend()
    end, 3)

    self:RegisterHitbox("ai_new_chat", newChatX, headerY, newChatW, headerH, function()
        self:ClearAIChat()
    end, 3)

    local chatX, chatY, chatW, chatH = self:GetAIChatBounds()
    local composerX, composerY, composerW, composerH, inputX, inputW, sendX, sendW = self:GetAIComposerBounds()
    local inputControl = self:GetAIInputControl()
    local inputValue = tostring(self:GetControlRawValue(inputControl, ""))
    local trimmedInput = self:TrimText(inputValue)
    local inputActive = self.activeTextInput == "ai_prompt_input"
    local inputShown = inputValue

    if inputActive and self.searchCursor then
        inputShown = inputShown .. "|"
    end

    if inputShown == "" and not inputActive then
        inputShown = tostring(inputControl and (inputControl.placeholder or inputControl.Placeholder) or "Message MatchaMind...")
    end

    if bucket then
        self:DrawFastBox(bucket, chatX, chatY, chatW, chatH, Theme.bg, Theme.border, 1)
    end

    local messages = {}
    local hasUserMessage = false
    for _, message in ipairs(self.aiMessages or {}) do
        if message and message.role == "user" then
            hasUserMessage = true
        end
        table.insert(messages, message)
    end

    if self.aiIsSending then
        table.insert(messages, {
            role = "assistant",
            text = self.aiActiveJobId and "Waiting for reply..." or "MatchaMind is thinking...",
            pending = true,
        })
    end

    local layouts = {}
    local totalH = 0
    local gap = 9
    local maxBubbleW = math.max(150, math.floor(chatW * 0.72))

    for index, message in ipairs(messages) do
        local role = tostring((message and message.role) or "assistant")
        local text = tostring((message and message.text) or "")
        local lines = self:WrapText(text, maxBubbleW - 18, 13)
        if #lines > 12 then
            while #lines > 12 do
                table.remove(lines)
            end
            lines[#lines] = self:TruncateText(tostring(lines[#lines] or "") .. " ...", maxBubbleW - 18, 13)
        end

        local widest = self:EstimateTextWidth(role == "user" and "You" or "MatchaMind", 12)
        for _, line in ipairs(lines) do
            widest = math.max(widest, self:EstimateTextWidth(line, 13))
        end

        local bubbleW = math.min(maxBubbleW, math.max(132, widest + 20))
        local bubbleH = 27 + (#lines * 15)
        layouts[index] = {
            role = role,
            lines = lines,
            w = bubbleW,
            h = bubbleH,
            pending = message and message.pending == true,
        }

        if index > 1 then
            totalH = totalH + gap
        end
        totalH = totalH + bubbleH
    end

    local viewTop = chatY + 8
    local viewBottom = chatY + chatH - 8
    local viewportH = math.max(1, viewBottom - viewTop)
    self.aiChatContentHeight = totalH
    self.aiChatViewportHeight = viewportH
    self.aiChatScrollMax = math.max(0, totalH - viewportH)

    if self.aiScrollToLatest then
        self.aiChatScroll = self.aiChatScrollMax
    else
        self.aiChatScroll = math.clamp(self.aiChatScroll or 0, 0, self.aiChatScrollMax)
    end

    if bucket and #layouts == 0 and not hasUserMessage and not self.aiIsSending then
        local centerX = chatX + math.floor(chatW * 0.5)
        local centerY = chatY + math.floor(chatH * 0.5) - 16
        self:CreateText(bucket, "What can I help with?", centerX, centerY, Theme.text, 18, true)
        self:CreateText(bucket, "Ask MatchaMind anything.", centerX, centerY + 24, Theme.textMuted, 13, true)
    end

    local cursorY = viewTop - (self.aiChatScroll or 0)
    for _, layout in ipairs(layouts) do
        local bubbleY = cursorY
        local bubbleBottom = bubbleY + layout.h
        local intersects = bubbleBottom >= viewTop and bubbleY <= viewBottom

        if bucket and intersects then
            local isUser = layout.role == "user"
            local bubbleX = isUser and (chatX + chatW - layout.w - 12) or (chatX + 12)
            local fill = isUser and Theme.panelAlt or Theme.panel
            local border = isUser and Theme.accent or Theme.border
            local textColor = layout.pending and Theme.textMuted or Theme.text
            local boxY = math.max(bubbleY, viewTop)
            local boxBottom = math.min(bubbleBottom, viewBottom)
            local boxH = math.max(0, boxBottom - boxY)

            if boxH > 0 then
                self:DrawFastBox(bucket, bubbleX, boxY, layout.w, boxH, fill, border, 1)
            end

            local headerText = isUser and "You" or "MatchaMind"
            local headerY = bubbleY + 6
            if headerY >= viewTop and (headerY + 12) <= viewBottom then
                self:CreateText(bucket, headerText, bubbleX + 9, headerY, isUser and Theme.accent or Theme.textDim, 12, false)
            end

            for lineIndex, line in ipairs(layout.lines) do
                local lineY = bubbleY + 21 + ((lineIndex - 1) * 15)
                if lineY >= viewTop and (lineY + 14) <= viewBottom then
                    self:CreateText(bucket, line, bubbleX + 9, lineY, textColor, 13, false)
                end
            end
        end

        cursorY = bubbleY + layout.h + gap
    end

    if self.aiChatScrollMax > 0 then
        local trackX = chatX + chatW - 5
        local trackH = math.max(1, viewBottom - viewTop)
        local thumbH = math.max(24, math.floor(trackH * (viewportH / math.max(viewportH, totalH))))
        local available = math.max(1, trackH - thumbH)
        local thumbY = viewTop + math.floor(available * ((self.aiChatScroll or 0) / math.max(1, self.aiChatScrollMax)))
        if bucket then
            self:CreateSquare(bucket, trackX, viewTop, 2, trackH, Theme.panel, 0.85, true)
            self:CreateSquare(bucket, trackX, thumbY, 2, thumbH, Theme.accent, 1, true)
        end
        self:RegisterHitbox("ai_chat_scrollbar", trackX - 8, thumbY - 4, 18, thumbH + 8, function()
            self.draggingAIChatScroll = true
            self.aiScrollToLatest = false
            self.aiScrollDragOffset = self:GetMouseLocation().Y - thumbY
        end, 4)
    end

    local showJump = self.aiChatScrollMax > 0 and (self.aiChatScroll or 0) < (self.aiChatScrollMax - 8)
    if showJump then
        local jumpW = 110
        local jumpH = 24
        local jumpX = chatX + chatW - jumpW - 12
        local jumpY = chatY + chatH - jumpH - 10

        if bucket then
            self:DrawFastBox(bucket, jumpX, jumpY, jumpW, jumpH, self.hoveredId == "ai_jump_latest" and Theme.panelAlt or Theme.panel, Theme.accent, 1)
            self:CreateText(bucket, "Jump To Latest", jumpX + math.floor(jumpW * 0.5), jumpY + 5, Theme.text, 13, true)
        end

        self:RegisterHitbox("ai_jump_latest", jumpX, jumpY, jumpW, jumpH, function()
            self.aiScrollToLatest = true
            self.aiChatScroll = self.aiChatScrollMax or 0
            self:MarkCurrentTabDirty()
        end, 5)
    end

    local canSend = trimmedInput ~= "" and not self.aiIsSending
    local sendFill = canSend and Theme.panelAlt or Theme.bg
    local sendTextColor = canSend and Theme.text or Theme.textMuted

    if bucket then
        self:DrawFastBox(bucket, composerX, composerY, composerW, composerH, Theme.panel, Theme.border, 1)
        self:DrawFastBox(bucket, inputX + 6, composerY + 7, inputW - 6, composerH - 14, Theme.bg, inputActive and Theme.accent or Theme.border, 1)
        self:CreateText(bucket, self:TruncateText(inputShown, inputW - 24, 14), inputX + 15, composerY + 18, inputValue == "" and not inputActive and Theme.textMuted or Theme.text, 14, false)
        self:DrawFastBox(bucket, sendX, composerY + 7, sendW, composerH - 14, sendFill, canSend and Theme.accent or Theme.border, canSend and 1 or 0.75)
        self:CreateText(bucket, self.aiIsSending and "Thinking" or "Send", sendX + math.floor(sendW * 0.5), composerY + 18, sendTextColor, 14, true)
    end

    self:RegisterHitbox("ai_prompt_input_box", inputX + 6, composerY + 7, inputW - 6, composerH - 14, function()
        self:FocusTextControl("ai_prompt_input")
    end, 4)

    self:RegisterHitbox("ai_send_button", sendX, composerY + 7, sendW, composerH - 14, function()
        self:SendAIMessage()
    end, 4)
end

function UI:DrawObsidianActiveTab(bucket)
    if self.selectedTab == self.aiTabIndex then
        return self:DrawAIChatTab(bucket)
    end

    local x, y, width, height = self:GetContentBounds()
    local columns = self:BuildObsidianGroups()
    local gap = 6
    local usableWidth = math.max(1, width - self:GetScrollbarGutter())
    local colW = math.max(1, math.floor((usableWidth - gap - 4) * 0.5))
    local colX = {
        x + 2,
        x + 2 + colW + gap,
    }
    local contentTop = y + 2 + math.floor((self.contentOffset or 0) + 0.5) - self.scroll.offset
    local contentBottom = y + height - 2

    for side = 1, 2 do
        local cursorY = contentTop
        for _, group in ipairs(columns[side]) do
            local innerX = colX[side] + 7
            local innerW = math.max(1, colW - 14)
            local groupH = self:GetGroupHeight(group, innerW)
            local visible = cursorY + groupH >= y and cursorY <= contentBottom

            if visible then
                self:DrawObsidianGroupFrame(bucket, group, colX[side], cursorY, colW, groupH)
                local controlY = cursorY + 42
                for index, control in ipairs(group.controls) do
                    if index > 1 then
                        controlY = controlY + 8
                    end
                    local controlH = self:GetControlHeight(control, innerW)
                    if controlY + controlH >= y and controlY <= contentBottom then
                        self:DrawObsidianControl(bucket, control, innerX, controlY, innerW, contentBottom)
                    end
                    controlY = controlY + controlH
                end
            end

            cursorY = cursorY + groupH + 6
        end
    end
end

function UI:RegisterActiveTabHitboxes()
    if self.selectedTab == self.aiTabIndex then
        self:DrawAIChatTab(nil)
        return
    end

    self:DrawObsidianActiveTab(nil)

    local scrollbarX, scrollbarY, scrollbarW, scrollbarH, thumbY, thumbH = self:GetScrollbarMetrics()
    if self.scroll.max > 0 then
        local animatedThumbY = math.floor((self.animatedScrollThumbY or thumbY) + 0.5)
        self:RegisterHitbox("scrollbar_thumb", scrollbarX - 10, animatedThumbY - 2, scrollbarW + 20, thumbH + 4, function()
            self.draggingScroll = true
            self.scrollDragOffset = self:GetMouseLocation().Y - animatedThumbY
        end, 3)
    end
end

