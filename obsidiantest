function UI:GetSliderDisplay(control)
    local value = self:GetControlRawValue(control, 0)
    local formatter = control.formatDisplay or control.FormatDisplayValue

    if type(formatter) == "function" then
        local ok, value = pcall(formatter, control, value)
        if ok and value ~= nil then
            return tostring(value)
        end
    end

    value = tonumber(value) or 0
    local prefix = tostring(control.prefix or control.Prefix or "")
    local suffix = tostring(control.suffix or control.Suffix or "")
    local maxValue = control.max or control.Max or 0

    if control.compact or control.Compact then
        return string.format("%s: %s", self:GetControlLabel(control), tostring(value))
    end

    if control.hideMax or control.HideMax then
        return prefix .. tostring(value) .. suffix
    end

    return prefix .. tostring(value) .. suffix .. "/" .. prefix .. tostring(maxValue) .. suffix
end

function UI:DrawToggle(bucket, control, x, y, w, h)
    local controlId = self:GetControlId(control)
    local active = self:GetControlRawValue(control, false) == true
    local fill = self.animationState.toggleFill[controlId] or (active and 1 or 0)
    local disabled = self:IsControlDisabled(control)
    local switchW = 32
    local switchH = 18
    local switchX = x + w - switchW
    local switchY = y
    local fillColor = disabled and Theme.bg or LerpColor(Theme.panel, Theme.accent, fill)
    local outlineColor = disabled and Theme.borderSoft or LerpColor(Theme.border, Theme.accent, fill)
    local ballX = switchX + 2 + math.floor((switchW - switchH) * fill)
    local ballColor = disabled and Theme.textMuted or Theme.text

    self:CreateText(bucket, self:GetControlLabel(control), x, y + 2, disabled and Theme.textMuted or LerpColor(Theme.textDim, Theme.text, fill), 14, false)
    self:DrawFastBox(bucket, switchX, switchY, switchW, switchH, fillColor, outlineColor, disabled and 0.65 or 1)
    self:CreateSquare(bucket, ballX, switchY + 2, switchH - 4, switchH - 4, ballColor, disabled and 0.7 or 1, true)
end

function UI:DrawCheckbox(bucket, control, x, y, w, h)
