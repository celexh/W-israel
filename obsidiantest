function UI:GetSliderPercent(control)
    local minValue = control.min or control.Min or 0
    local maxValue = control.max or control.Max or 1
    local value = self:GetControlRawValue(control, minValue)
    if maxValue <= minValue then
        return 0
    end

    return math.clamp((value - minValue) / (maxValue - minValue), 0, 1)
end

function UI:SetSliderValue(control, percent)
    if not control then
        return
    end

    local minValue = control.min or control.Min or 0
    local maxValue = control.max or control.Max or 1
    local stepValue = control.step or control.Step
    local rounding = control.rounding or control.Rounding

    local rawValue = minValue + ((maxValue - minValue) * math.clamp(percent, 0, 1))
    local steppedValue = rawValue
    if stepValue then
        steppedValue = minValue + math.floor(((rawValue - minValue) / stepValue) + 0.5) * stepValue
    elseif rounding then
        steppedValue = tonumber(string.format("%." .. tostring(rounding) .. "f", rawValue)) or rawValue
    else
        steppedValue = math.floor(rawValue + 0.5)
    end
    steppedValue = math.clamp(steppedValue, minValue, maxValue)

    if self:GetControlRawValue(control, nil) ~= steppedValue then
        self:SetControlRawValue(control, steppedValue)

        if self:GetControlId(control) == "tween_speed" then
            if steppedValue > 120 and not self.tweenSpeedWarned then
                self.tweenSpeedWarned = true
                self:NotifyPlayer("Tween speeds above 120 may get you banned", "Windy", 4)
            elseif steppedValue <= 120 then
                self.tweenSpeedWarned = false
            end
        end

        self:RunAction(control, steppedValue)
        self:MarkCurrentTabDirty()
        self:SaveConfig(false)
    end
end

