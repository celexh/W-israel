    if UI then
        UI:Destroy()
    end
end

UI:SetupAIWheelScroll()

UI.renderConnection = RunService.RenderStepped:Connect(function(dt)
    if not UI.isRunning then
        return
    end

    if not UI.isBooting then
        pcall(function()
            UI:HandleHotkeys()
        end)

        pcall(function()
            UI:UpdateRobloxInputCapture()
        end)

        if not UI.uiVisible then
            if not UI.hiddenCleared then
                UI:ClearAllBuckets()
                UI.hiddenCleared = true
            end
            UI.animationsActive = false
            UI.needsRedraw = false
            pcall(function()
                UI:DebugPerfReport(false)
            end)
            return
        end

        UI.hiddenCleared = false
    end

    UI:UpdateRainbowAccent()

    if UI.isBooting then
        local oldProgress = UI.loadingAnimatedProgress or 0
        local oldReady = UI.bootReady == true

        pcall(function()
            if not UI:AreUIImagesDisabled() then
                UI:GetLogoImageData()
            end
            UI:GetLoadingLogoImageData()
            UI:GetLoadingSpinnerImageData()
        end)

        UI:UpdateLoadingAnimation(dt or (1 / 60))

        if (tick() - UI.bootStartedAt) >= UI.bootDuration
            and (UI.bootVisualProgress or 0) >= 0.999
            and UI:IsLogoImageReady()
            and UI:IsLoadingAssetsReady()
        then
            UI.bootReady = true
        end

        if UI.bootReady then
            UI.bootReadyAt = UI.bootReadyAt or tick()

            if tick() - UI.bootReadyAt >= 0.45 then
                UI.isBooting = false
                UI.bootReady = false

                if UI:AreAnimationsEnabled() then
                    UI.uiAlpha = 0
                    UI.renderScale = 0.82
                    UI.contentAlpha = 0
                    UI.contentOffset = 4
                else
                    UI.uiAlpha = 1
                    UI.renderScale = 1
                    UI.contentAlpha = 1
                    UI.contentOffset = 0
                end

                UI.needsRedraw = true
            end
        end

        local now = tick()
        if (now - (UI.lastLoadingRedraw or 0)) >= (1 / 30)
            or (UI.bootReady == true) ~= oldReady
        then
            UI.lastLoadingRedraw = now
            UI.needsRedraw = true
        end
    end

    local inputChanged = false
    local activeInteraction = false

    if not UI.isBooting then
        pcall(function()
            inputChanged = UI:PollFrameInputChanged()
        end)

        pcall(function()
            UI:RefreshHomeStats(false)
        end)

        pcall(function()
            UI:UpdateAIRequestTimeout()
        end)

        pcall(function()
            UI:UpdateAIPolling()
        end)

        activeInteraction = UI:HasActiveInteraction()
    end

    if UI.isBooting or UI.needsRedraw or UI.animationsActive or inputChanged or activeInteraction then
        pcall(function()
            UI:UpdateAnimations(dt or (1 / 60))
        end)
    end

    if UI.searchFocused or UI.activeTextInput or UI.activeDropdownSearch then
        pcall(function()
            UI:PollSearchKeys()
        end)
    end

    if UI.activeKeybind then
        pcall(function()
            UI:PollKeybindCapture()
        end)
    end

    if UI.isBooting then
        pcall(function()
            UI:HandleHotkeys()
        end)
    end

    if UI.isBooting then
        pcall(function()
            UI:HandleInput()
        end)
    elseif UI.uiVisible and (UI.uiAlpha or 0) > 0.9 and (UI.renderScale or 1) > 0.98 then
        if inputChanged or activeInteraction then
            pcall(function()
                UI:HandleInput()
            end)
        end

        pcall(function()
            UI:HandleTransientEffects()
        end)
    end

    if UI.needsRedraw then
        pcall(function()
            UI:Render()
        end)
    end

    pcall(function()
        UI:DebugPerfReport(false)
    end)
end)
