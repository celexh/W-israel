UI.actions = {}

function UI:AddAction(controlId, callback)
    if type(controlId) ~= "string" or controlId == "" then
        return false
    end

    if type(callback) ~= "function" then
        return false
    end

    self.actions[controlId] = callback
    return true
end

function UI:RunAction(control, ...)
    if not control then
        return
    end

    local controlId = self:GetControlId(control)
    local callback = self.actions[controlId] or control.callback or control.Callback or control.Func
    if type(callback) ~= "function" then
        return
    end

    local ok, err = pcall(callback, control, ...)
    if not ok then
        warn("[UI ACTION ERROR]", tostring(controlId), tostring(err))
    end
end

function UI:GetControlById(controlId)
    for tabIndex, tabControls in ipairs(self.controls or {}) do
        for _, control in ipairs(tabControls) do
            if control.id == controlId or control.Idx == controlId or control.idx == controlId or control._drawId == controlId then
                return control, tabIndex
            end
        end
    end

    return nil, nil
end

function UI:SetControlValue(controlId, value, skipAction)
    local control, tabIndex = self:GetControlById(controlId)
    if not control then
        return false
    end

    local controlType = self:GetControlType(control)
    local resolvedId = self:GetControlId(control)

    if controlType == "dropdown_multi" then
        return false
    end

    if self:GetControlRawValue(control, nil) == value then
        return true
    end

    self:SetControlRawValue(control, value)

    if resolvedId == "ui_scale" then
        self.window.width = tonumber(value) or self.window.width
        self:MarkShellDirty()
    elseif resolvedId == "ui_height" then
        self.window.height = tonumber(value) or self.window.height
        self:MarkShellDirty()
    elseif resolvedId == "accent_theme" then
        self:ApplyAccentTheme(value)
        self:MarkShellDirty()
    end

    self:MarkTabDirty(tabIndex or self.selectedTab)

    if not skipAction then
        self:RunAction(control, value)
    end

    self:SaveConfig(false)
    return true
end

function UI:GetControlValue(controlId, fallback)
    local control = self:GetControlById(controlId)
    if not control then
        return fallback
    end

    if self:GetControlType(control) == "dropdown_multi" then
        return control.selected or control.Selected or self:GetControlRawValue(control, fallback)
    end

    if self:GetControlRawValue(control, nil) == nil then
        return fallback
    end

    return self:GetControlRawValue(control, fallback)
end

function UI:GetControlType(control)
    local controlType = control and (control.type or control.Type) or ""
    local variant = control and (control.variant or control.Variant) or ""

    if controlType == "Toggle" and variant == "Checkbox" then
        return "checkbox"
    elseif controlType == "Toggle" then
        return "toggle"
    elseif controlType == "Dropdown" then
        return (control.Multi or control.multi) and "dropdown_multi" or "dropdown_single"
    elseif controlType == "Input" then
        return "input"
    elseif controlType == "Slider" then
        return "slider"
    elseif controlType == "Button" or controlType == "SubButton" then
        return "button"
    elseif controlType == "Label" then
        return "label"
    elseif controlType == "Divider" then
        return "divider"
    elseif controlType == "KeyPicker" then
        return "keybind"
    elseif controlType == "ColorPicker" then
        return "colorpicker"
    end

    controlType = tostring(controlType):lower()
    if controlType == "keypicker" or controlType == "keybind" or controlType == "key_bind" then
        return "keybind"
    elseif controlType == "colorpicker" or controlType == "color_picker" then
        return "colorpicker"
    end

    return controlType
end

function UI:GetControlId(control)
    if not control then
        return "control"
    end

    if control.id then
        return tostring(control.id)
    end

    if not control._drawId then
        local base = control.Idx or control.idx or control.Text or control.text or control.label or control.name or "control"
        control._drawId = tostring(base):gsub("%s+", "_"):lower() .. "_" .. tostring(control._groupOrder or 0)
    end

    return control._drawId
end

function UI:GetControlRawValue(control, fallback)
    if not control then
        return fallback
    end

    if control.value ~= nil then
        return control.value
    elseif control.Value ~= nil then
        return control.Value
    elseif control.default ~= nil then
        return control.default
    elseif control.Default ~= nil then
        return control.Default
    end

    return fallback
end

function UI:SetControlRawValue(control, value)
    if not control then
        return
    end

    control.value = value
    if control.Value ~= nil then
        control.Value = value
    end
end

function UI:GetControlOptions(control)
    return (control and (control.options or control.Values or control.values)) or {}
end

function UI:IsDropdownSearchable(control)
    return control and (control.searchable == true or control.Searchable == true)
end

function UI:FormatDropdownListValue(control, value)
    local formatter = control and (control.formatListValue or control.FormatListValue)
    if type(formatter) == "function" then
        local ok, formatted = pcall(formatter, value)
        if ok and formatted ~= nil then
            return tostring(formatted)
        end
    end

    return tostring(value)
end

function UI:GetVisibleDropdownOptions(control)
    local options = self:GetControlOptions(control)
    if not self:IsDropdownSearchable(control) then
        return options
    end

    local controlId = self:GetControlId(control)
    local query = self:TrimText(self.dropdownSearchText[controlId] or ""):lower()
    if query == "" then
        return options
    end

    local filtered = {}
    for _, option in ipairs(options) do
        local label = self:FormatDropdownListValue(control, option):lower()
        if string.find(label, query, 1, true) then
            table.insert(filtered, option)
        end
    end

    return filtered
end

function UI:GetSubButton(control)
    return control and (control.subButton or control.SubButton or control.subbutton) or nil
end

function UI:IsControlVisible(control)
    return control and control.visible ~= false and control.Visible ~= false
end

function UI:GetColorValue(control)
    local value = self:GetControlRawValue(control, nil)
    if value then
        local ok, r, g, b = pcall(function()
            return value.R, value.G, value.B
        end)
        if ok and r ~= nil and g ~= nil and b ~= nil then
            return value
        end
    end

    return Theme.accent
end

function UI:SetColorValue(control, color)
    if not control or not color then
        return
    end

    self:SetControlRawValue(control, color)
    self.expandedColorPicker = nil
    self:RunAction(control, color)
    self:UpdateScrollLimit()
    self:MarkCurrentTabDirty()
    self:SaveConfig(false)
end

function UI:SerializeControlValue(control, value)
    if self:GetControlType(control) == "colorpicker" and value then
        local ok, r, g, b = pcall(function()
            return value.R, value.G, value.B
        end)
        if ok and r ~= nil and g ~= nil and b ~= nil then
            return {__color3 = true, r = r, g = g, b = b}
        end
    end

    return value
end

function UI:DeserializeControlValue(value)
    if type(value) == "table" and value.__color3 == true then
        return Color3.new(tonumber(value.r) or 0, tonumber(value.g) or 0, tonumber(value.b) or 0)
    end

    return value
end

function UI:GetKeybindDisplay(control)
    local value = self:GetControlRawValue(control, nil)
    if value == nil or value == "" then
        value = control.Default or "None"
    end

    return tostring(value)
end

function UI:EstimateTextWidth(text, size)
    return math.floor(#tostring(text or "") * ((size or 14) * 0.54))
end

function UI:TruncateText(text, maxWidth, size)
    local content = tostring(text or "")
    if self:EstimateTextWidth(content, size) <= maxWidth then
        return content
    end

    local maxChars = math.max(3, math.floor(maxWidth / ((size or 14) * 0.54)))
    return content:sub(1, math.max(1, maxChars - 3)) .. "..."
end

function UI:WrapText(text, maxWidth, size)
    local content = tostring(text or "")
    local maxChars = math.max(8, math.floor(maxWidth / ((size or 14) * 0.54)))
    local lines = {}
    local current = ""

    for word in content:gmatch("%S+") do
        if current == "" then
            current = word
        elseif #(current .. " " .. word) <= maxChars then
            current = current .. " " .. word
        else
            table.insert(lines, current)
            current = word
        end
    end

    if current ~= "" then
        table.insert(lines, current)
    end

    if #lines == 0 then
        table.insert(lines, "")
    end

    return lines
end

function UI:GetRenderTransparency(value)
    return math.clamp((value or 1) * (self.renderAlpha or 1), 0, 1)
end

function UI:SetDrawingProperty(obj, property, value, epsilon)
    local current = obj[property]
    if type(current) == "number" and type(value) == "number" then
        if NearlyEqual(current, value, epsilon) then
            return false
        end
    elseif current == value then
        return false
    end

    obj[property] = value
    return true
end

function UI:GetBucketZBase(bucket)
    if bucket == self.loadingBucket then
        return 400000
    end

    if bucket == self.shellBucket then
        return 0
    end

    return 200000
end

function UI:SetDrawingZIndex(obj, z, bucket)
    if not obj then
        return
    end

    local finalZ = z or 0
    if bucket then
        finalZ = self:GetBucketZBase(bucket) + finalZ + (bucket.cursor or 0)
    end

    pcall(function()
        obj.ZIndex = finalZ
    end)
end

function UI:IsShellHitboxId(id)
    return type(id) == "string"
        and (
            string.sub(id, 1, 4) == "tab_"
            or id == "search_box"
            or id == "window_drag"
            or id == "window_resize"
        )
end

function UI:BeginBucket(bucket)
    if not bucket then
        return
    end

    bucket.cursor = 0
    bucket.deferVisible = true
end

function UI:SetDrawingClass(obj, className)
    if not obj then
        return
    end

    pcall(function()
        obj._className = className
    end)

    self.drawingClasses = self.drawingClasses or setmetatable({}, { __mode = "k" })
    self.drawingClasses[obj] = className
end

function UI:GetDrawingClass(obj)
    if not obj then
        return nil
    end

    local ok, className = pcall(function()
        return obj._className
    end)

    if ok and className then
        return className
    end

    return self.drawingClasses and self.drawingClasses[obj] or nil
end

function UI:AcquireDrawing(bucket, className)
    if not bucket then
        local ok, obj = pcall(Drawing.new, className)
        if not ok or not obj then
            return nil
        end
        self:SetDrawingClass(obj, className)
        return obj
    end

    bucket.cursor = (bucket.cursor or 0) + 1
    local index = bucket.cursor
    local obj = bucket.objects[index]
    local oldObj = nil

    if obj and self:GetDrawingClass(obj) ~= className then
        pcall(function()
            obj.Visible = false
        end)

        oldObj = obj
        obj = nil
    end

    if not obj then
        local ok, newObj = pcall(Drawing.new, className)
        if not ok or not newObj then
            bucket.cursor = index - 1
            return nil
        end

        obj = newObj
        self:SetDrawingClass(obj, className)
        bucket.objects[index] = obj

        if oldObj then
            bucket.orphans = bucket.orphans or {}
            table.insert(bucket.orphans, oldObj)
        end
    end

    return obj
end

function UI:EndBucket(bucket)
    if not bucket then
        return
    end

    local cursor = bucket.cursor or 0
    local objects = bucket.objects or {}
    local orphans = bucket.orphans or {}

    for index = 1, #objects do
        local obj = objects[index]
        if obj then
            pcall(function()
                obj.Visible = index <= cursor
            end)
        end
    end

    for index = cursor + 1, #objects do
        local obj = objects[index]
        if obj then
            pcall(function()
                obj.Visible = false
            end)
        end
    end

    for index = 1, #orphans do
        local obj = orphans[index]
        if obj then
            pcall(function()
                obj.Visible = false
            end)
        end
    end

    bucket.visible = true
    bucket.built = true
    bucket.deferVisible = false
end

function UI:DestroyBucket(bucket)
    if not bucket then
        return
    end

    local buckets = {
        bucket.objects or {},
        bucket.orphans or {},
    }

    for _, list in ipairs(buckets) do
        for index = 1, #list do
            local obj = list[index]
            if obj then
                pcall(function()
                    obj.Visible = false
                end)
                pcall(function()
                    obj:Remove()
                end)
                pcall(function()
                    obj.Visible = false
                end)
            end
        end
    end

    bucket.objects = {}
    bucket.orphans = {}
    bucket.cursor = 0
    bucket.visible = false
    bucket.built = false
    bucket.deferVisible = false
end

function UI:ClearBucket(bucket)
    if not bucket then
        return
    end

    bucket.cursor = 0
    local buckets = {
        bucket.objects or {},
        bucket.orphans or {},
    }

    for _, list in ipairs(buckets) do
        for index = 1, #list do
            local obj = list[index]
            if obj then
                pcall(function()
                    obj.Visible = false
                end)
            end
        end
    end

    bucket.visible = false
    bucket.built = false
    bucket.deferVisible = false
end

function UI:Destroy()
    self.isRunning = false
    self:SetRobloxInputEnabled(true)

    if self.renderConnection then
        pcall(function()
            self.renderConnection:Disconnect()
        end)
        pcall(function()
            self.renderConnection:disconnect()
        end)
    end

    if self.aiWheelConnection then
        pcall(function()
            self.aiWheelConnection:Disconnect()
        end)
        pcall(function()
            self.aiWheelConnection:disconnect()
        end)
    end

    self:DestroyBucket(self.shellBucket)
    self:DestroyBucket(self.loadingBucket)

    for _, bucket in ipairs(self.tabBuckets or {}) do
        self:DestroyBucket(bucket)
    end

    self.hitboxes = {}
    self.hoveredId = nil
    self.drawingClasses = setmetatable({}, { __mode = "k" })
    self.renderConnection = nil
    self.aiWheelConnection = nil
end

function UI:ClearAllBuckets()
    self:ClearBucket(self.shellBucket)
    self:ClearBucket(self.loadingBucket)

    for _, bucket in ipairs(self.tabBuckets or {}) do
        self:ClearBucket(bucket)
    end

    self.hitboxes = {}
    self.hoveredId = nil
end

function UI:HideBucket(bucket)
    if not bucket then
        return
    end

    local buckets = {
        bucket.objects or {},
        bucket.orphans or {},
    }

    for _, list in ipairs(buckets) do
        for index = 1, #list do
            local obj = list[index]
            if obj then
                pcall(function()
                    obj.Visible = false
                end)
            end
        end
    end
    bucket.visible = false
end

function UI:ShowBucket(bucket)
    if not bucket then
        return
    end

    local cursor = bucket.cursor or #(bucket.objects or {})
    local objects = bucket.objects or {}
    local orphans = bucket.orphans or {}

    for index = 1, #objects do
        local obj = objects[index]
        if obj then
            pcall(function()
                obj.Visible = index <= cursor
            end)
        end
    end

    for index = cursor + 1, #objects do
        local obj = objects[index]
        if obj then
            pcall(function()
                obj.Visible = false
            end)
        end
    end

    for index = 1, #orphans do
        local obj = orphans[index]
        if obj then
            pcall(function()
                obj.Visible = false
            end)
        end
    end

    bucket.visible = true
end

function UI:CreateSquare(bucket, x, y, w, h, color, transparency, filled, thickness)
    local square = self:AcquireDrawing(bucket, "Square")
    if not square then
        return nil
    end

    local tx, ty = self:TransformPoint(x, y)
    local tw, th = self:TransformSize(w, h)
    self:SetDrawingProperty(square, "Position", Vector2.new(tx, ty))
    self:SetDrawingProperty(square, "Size", Vector2.new(tw, th))
    self:SetDrawingProperty(square, "Color", color)
    self:SetDrawingProperty(square, "Transparency", self:GetRenderTransparency(transparency or 1), 0.001)
    self:SetDrawingProperty(square, "Filled", filled ~= false)
    self:SetDrawingZIndex(square, square.Filled and 0 or 30000, bucket)
    self:SetDrawingProperty(square, "Visible", not (bucket and bucket.deferVisible))
    if not square.Filled then
        self:SetDrawingProperty(square, "Thickness", thickness or 1, 0.001)
    end
    return square
end

function UI:CreateText(bucket, text, x, y, color, size, center)
    local label = self:AcquireDrawing(bucket, "Text")
    if not label then
        return nil
    end

    local tx, ty = self:TransformPoint(x, y)

    self:SetDrawingProperty(label, "Text", text)
    self:SetDrawingProperty(label, "Position", Vector2.new(tx, ty))
    self:SetDrawingProperty(label, "Color", color)
    self:SetDrawingProperty(label, "Transparency", 1, 0.001)
    self:SetDrawingProperty(label, "Size", math.max(8, math.floor((size or 13) * (self.renderScale or 1) + 0.5)), 0.001)
    self:SetDrawingProperty(label, "Center", center or false)
    self:SetDrawingProperty(label, "Outline", true)
    self:SetDrawingZIndex(label, 100000, bucket)
    self:SetDrawingProperty(label, "Visible", not (bucket and bucket.deferVisible))
    self:SetDrawingProperty(label, "Font", 2)
    return label
end

function UI:CreateRightText(bucket, text, rightX, y, color, size)
    local content = tostring(text or "")
    local fontSize = size or 13
    local estimatedWidth = math.max(0, math.floor(#content * (fontSize * 0.52)))
    return self:CreateText(bucket, content, rightX - estimatedWidth, y, color, fontSize, false)
end

function UI:CreateLine(bucket, fromX, fromY, toX, toY, color, transparency, thickness)
    local line = self:AcquireDrawing(bucket, "Line")
    if not line then
        return nil
    end

    local tx1, ty1 = self:TransformPoint(fromX, fromY)
    local tx2, ty2 = self:TransformPoint(toX, toY)
    self:SetDrawingProperty(line, "From", Vector2.new(tx1, ty1))
    self:SetDrawingProperty(line, "To", Vector2.new(tx2, ty2))
    self:SetDrawingProperty(line, "Color", color)
    self:SetDrawingProperty(line, "Transparency", self:GetRenderTransparency(transparency or 1), 0.001)
    self:SetDrawingProperty(line, "Thickness", math.max(1, math.floor((thickness or 1) * (self.renderScale or 1) + 0.5)), 0.001)
    self:SetDrawingZIndex(line, 70000, bucket)
    self:SetDrawingProperty(line, "Visible", not (bucket and bucket.deferVisible))
    return line
end

function UI:CreateCircle(bucket, x, y, radius, color, transparency, filled, thickness)
    local circle = self:AcquireDrawing(bucket, "Circle")
    if not circle then
        return nil
    end

    local tx, ty = self:TransformPoint(x, y)
    self:SetDrawingProperty(circle, "Position", Vector2.new(tx, ty))
    self:SetDrawingProperty(circle, "Radius", math.max(1, radius * (self.renderScale or 1)), 0.001)
    self:SetDrawingProperty(circle, "Color", color)
    self:SetDrawingProperty(circle, "Transparency", self:GetRenderTransparency(transparency or 1), 0.001)
    self:SetDrawingProperty(circle, "Filled", filled ~= false)
    self:SetDrawingZIndex(circle, circle.Filled and 50000 or 60000, bucket)
    self:SetDrawingProperty(circle, "Visible", not (bucket and bucket.deferVisible))
    if not circle.Filled then
        self:SetDrawingProperty(circle, "Thickness", math.max(1, math.floor((thickness or 1) * (self.renderScale or 1) + 0.5)), 0.001)
    end
    return circle
end

function UI:GetLogoImageData()
    if self:AreUIImagesDisabled() then
        return nil
    end

    if self.logoImageUnsupported then
        return nil
    end

    if self.logoImageData or self.logoImageFailed then
        return self.logoImageData
    end

    local ok, data = pcall(function()
        return game:HttpGet(self.logoImageUrl)
    end)

    if ok and type(data) == "string" and data ~= "" then
        self.logoImageData = data
        return self.logoImageData
    end

    self.logoImageFailed = true
    return nil
end

function UI:GetCachedImageData(urlKey, dataKey, failedKey)
    if self.logoImageUnsupported then
        return nil
    end

    if self[dataKey] or self[failedKey] then
        return self[dataKey]
    end

    local url = self[urlKey]
    if type(url) ~= "string" or url == "" then
        self[failedKey] = true
        return nil
    end

    local ok, data = pcall(function()
        return game:HttpGet(url)
    end)

    if ok and type(data) == "string" and data ~= "" then
        self[dataKey] = data
        return data
    end

    self[failedKey] = true
    return nil
end

function UI:GetLoadingLogoImageData()
    return self:GetCachedImageData(
        "loadingLogoImageUrl",
        "loadingLogoImageData",
        "loadingLogoImageFailed"
    )
end

function UI:GetLoadingSpinnerImageData()
    return self:GetCachedImageData(
        "loadingSpinnerImageUrl",
        "loadingSpinnerImageData",
        "loadingSpinnerImageFailed"
    )
end

function UI:IsLoadingAssetsReady()
    local logoReady = self.loadingLogoImageData ~= nil
        or self.loadingLogoImageFailed == true
        or self.logoImageUnsupported == true

    local spinnerReady = self.loadingSpinnerImageData ~= nil
        or self.loadingSpinnerImageFailed == true
        or self.logoImageUnsupported == true

    return logoReady and spinnerReady
end

function UI:IsLogoImageReady()
    if self:AreUIImagesDisabled() then
        return true
    end

    return self.logoImageData ~= nil or self.logoImageFailed == true or self.logoImageUnsupported == true
end

function UI:GetTabIconData(tab)
    if self:AreUIImagesDisabled() then
        return nil
    end

    if self.logoImageUnsupported then
        return nil
    end

    if not tab or type(tab.iconUrl) ~= "string" or tab.iconUrl == "" then
        return nil
    end

    if tab.iconData or tab.iconFailed then
        return tab.iconData
    end

    local ok, data = pcall(function()
        return game:HttpGet(tab.iconUrl)
    end)

    if ok and type(data) == "string" and data ~= "" then
        tab.iconData = data
        return data
    end

    tab.iconFailed = true
    return nil
end

function UI:CreateImage(bucket, data, x, y, w, h, transparency)
    if self.logoImageUnsupported then
        return nil
    end

    local image = self:AcquireDrawing(bucket, "Image")
    if not image then
        self.logoImageUnsupported = true
        return nil
    end

    local tx, ty = self:TransformPoint(x, y)
    local tw, th = self:TransformSize(w, h)
    local applied = pcall(function()
        self:SetDrawingProperty(image, "Position", Vector2.new(tx, ty))
        self:SetDrawingProperty(image, "Size", Vector2.new(tw, th))
        self:SetDrawingZIndex(image, 80000, bucket)
        self:SetDrawingProperty(image, "Visible", not (bucket and bucket.deferVisible))
        self:SetDrawingProperty(image, "Transparency", self:GetRenderTransparency(transparency or 1), 0.001)
        self:SetDrawingProperty(image, "Data", data)
    end)

    if not applied then
        self.logoImageUnsupported = true
        pcall(function()
            image.Visible = false
        end)
        if bucket and bucket.objects and bucket.objects[bucket.cursor] == image then
            bucket.cursor = math.max(0, (bucket.cursor or 1) - 1)
        end
        return nil
    end

    return image
end

function UI:CreateRoundedBox(bucket, x, y, w, h, radius, color, transparency)
    radius = math.floor(math.max(0, math.min(radius or 0, math.min(w, h) / 2)))
    if radius <= 0 then
        self:CreateSquare(bucket, x, y, w, h, color, transparency or 1, true)
        return
    end

    self:CreateSquare(bucket, x + radius, y, w - (radius * 2), h, color, transparency or 1, true)
    self:CreateSquare(bucket, x, y + radius, w, h - (radius * 2), color, transparency or 1, true)
    self:CreateCircle(bucket, x + radius, y + radius, radius, color, transparency or 1, true)
    self:CreateCircle(bucket, x + w - radius, y + radius, radius, color, transparency or 1, true)
    self:CreateCircle(bucket, x + radius, y + h - radius, radius, color, transparency or 1, true)
    self:CreateCircle(bucket, x + w - radius, y + h - radius, radius, color, transparency or 1, true)
end

function UI:DrawRoundedWindow(bucket, x, y, w, h)
    local radius = 4

    -- Obsidian outline/shadow feel
    self:CreateRoundedBox(bucket, x - 1, y - 1, w + 2, h + 2, radius + 1, Theme.dark or Color3.new(0, 0, 0))
    self:CreateRoundedBox(bucket, x, y, w, h, radius, Theme.border)
    self:CreateRoundedBox(bucket, x + 1, y + 1, w - 2, h - 2, math.max(0, radius - 1), Theme.bg)
end

function UI:DrawLeftRoundedPanel(bucket, x, y, w, h, radius, color)
    radius = math.floor(math.max(0, radius or 0))

    -- middle body
    self:CreateSquare(bucket, x, y + radius, w, h - (radius * 2), color, 1, true)

    -- top/bottom body, shifted right so it does not cover rounded outside corners
    self:CreateSquare(bucket, x + radius, y, w - radius, radius, color, 1, true)
    self:CreateSquare(bucket, x + radius, y + h - radius, w - radius, radius, color, 1, true)

    -- left rounded corners
    self:CreateCircle(bucket, x + radius, y + radius, radius, color, 1, true)
    self:CreateCircle(bucket, x + radius, y + h - radius, radius, color, 1, true)

    -- fill the right side fully
    self:CreateSquare(bucket, x + radius, y, w - radius, h, color, 1, true)
end

function UI:DrawRoundedBar(bucket, x, y, w, h, fillPercent)
    local radius = 2
    local pct = math.clamp(fillPercent or 0, 0, 1)

    self:CreateRoundedBox(bucket, x, y, w, h, radius, Theme.border)
    self:CreateRoundedBox(bucket, x + 1, y + 1, w - 2, h - 2, radius, Theme.panel)

    local fillW = math.floor((w - 2) * pct)
    if fillW > 0 then
        self:CreateRoundedBox(bucket, x + 1, y + 1, fillW, h - 2, radius, Theme.accent)
    end
end

function UI:AnimateValue(store, key, target, speed, dt, defaultValue)
    local current = store[key]
    if current == nil then
        current = defaultValue ~= nil and defaultValue or target
    end

    local nextValue = LerpNumber(current, target, SmoothFactor(speed or 12, dt))
    if math.abs(nextValue - target) < 0.001 then
        nextValue = target
    end

    store[key] = nextValue
    return nextValue, nextValue ~= target
end

function UI:GetAnimatedWindowYOffset()
    return math.floor(self.uiOffset + 0.5)
end

function UI:GetViewportSize()
    local camera = workspace and workspace.CurrentCamera or nil
    if camera and camera.ViewportSize then
        return camera.ViewportSize
    end

    return Vector2.new(1280, 720)
end

function UI:GetRenderWindowPosition()
    return math.floor((self.renderX or self.window.x) + 0.5), math.floor((self.renderY or self.window.y) + 0.5)
end

function UI:GetTransformCenter()
    local renderX, renderY = self:GetRenderWindowPosition()
    local baseY = renderY + self:GetAnimatedWindowYOffset()
    return renderX + (self.window.width * 0.5), baseY + (self.window.height * 0.5)
end

function UI:TransformPoint(x, y)
    local scale = self.renderScale or 1
    if math.abs(scale - 1) < 0.001 then
        return x, y
    end

    local centerX, centerY = self:GetTransformCenter()
    return centerX + ((x - centerX) * scale), centerY + ((y - centerY) * scale)
end

function UI:TransformSize(w, h)
    local scale = self.renderScale or 1
    if math.abs(scale - 1) < 0.001 then
        return w, h
    end

    return w * scale, h * scale
end

function UI:ResetContentAnimation()
    self.contentAlpha = 0
    self.contentOffset = 6
    self:MarkCurrentTabDirty()
end

function UI:UpdateAnimations(dt)
    local tabStartY = 58
    local tabStep = 40

    if not self:AreAnimationsEnabled() then
        self.uiAlpha = self.uiVisible and 1 or 0
        self.uiOffset = 0
        self.renderX = self.window.x
        self.renderY = self.window.y
        self.renderScale = 1
        self.contentAlpha = self.uiVisible and 1 or 0
        self.contentOffset = 0
        self.activeTabHighlightY = tabStartY + ((self.selectedTab - 1) * tabStep)

        for tabIndex = 1, #self.tabs do
            self.animationState.tabHover[tabIndex] = self.hoveredId == ("tab_" .. tostring(tabIndex)) and 1 or 0
            self.animationState.tabActive[tabIndex] = self.selectedTab == tabIndex and 1 or 0
        end

        for _, tabControls in ipairs(self.controls or {}) do
            for _, control in ipairs(tabControls) do
                local controlType = self:GetControlType(control)
                local controlId = self:GetControlId(control)
                self.animationState.controlHover[controlId] = self.hoveredId == controlId and 1 or 0
                self.animationState.dropdownOpen[controlId] = self.expandedDropdown == controlId and 1 or 0

                if controlType == "slider" then
                    self.animationState.sliderFill[controlId] = self:GetSliderPercent(control)
                elseif controlType == "toggle" then
                    self.animationState.toggleFill[controlId] = self:GetControlRawValue(control, false) and 1 or 0
                elseif controlType == "checkbox" then
                    self.animationState.checkboxFill[controlId] = self:GetControlRawValue(control, false) and 1 or 0
                end
            end
        end

        local _, _, _, _, thumbTargetY = self:GetScrollbarMetrics()
        self.animatedScrollThumbY = thumbTargetY
        self.animationsActive = false
        return
    end

    local shellAnimating = false
    local tabAnimating = false

    local alphaTarget = self.uiVisible and 1 or 0
    self.uiAlpha = LerpNumber(self.uiAlpha or alphaTarget, alphaTarget, SmoothFactor(16, dt))
    if math.abs(self.uiAlpha - alphaTarget) < 0.002 then
        self.uiAlpha = alphaTarget
    else
        shellAnimating = true
        tabAnimating = true
    end

    local offsetTarget = self.uiVisible and 0 or 10
    self.uiOffset = LerpNumber(self.uiOffset or offsetTarget, offsetTarget, SmoothFactor(16, dt))
    if math.abs(self.uiOffset - offsetTarget) >= 0.02 then
        shellAnimating = true
        tabAnimating = true
    else
        self.uiOffset = offsetTarget
    end

    self.renderX = self.window.x
    self.renderY = self.window.y

    local scaleTarget = self.uiVisible and 1 or 0.2
    self.renderScale = LerpNumber(self.renderScale or scaleTarget, scaleTarget, SmoothFactor(16, dt))
    if math.abs((self.renderScale or scaleTarget) - scaleTarget) >= 0.002 then
        shellAnimating = true
        tabAnimating = true
    else
        self.renderScale = scaleTarget
    end

    local contentTarget = self.uiVisible and 1 or 0
    self.contentAlpha = LerpNumber(self.contentAlpha or contentTarget, contentTarget, SmoothFactor(14, dt))
    self.contentOffset = LerpNumber(self.contentOffset or 0, self.uiVisible and 0 or 4, SmoothFactor(14, dt))

    if math.abs(self.contentAlpha - contentTarget) >= 0.002
        or math.abs(self.contentOffset - (self.uiVisible and 0 or 4)) >= 0.02
    then
        tabAnimating = true
    else
        self.contentAlpha = contentTarget
        self.contentOffset = self.uiVisible and 0 or 4
    end

    local activeTabTargetY = tabStartY + ((self.selectedTab - 1) * tabStep)

    if self.draggingWindow then
        self.activeTabHighlightY = activeTabTargetY
    else
        self.activeTabHighlightY = LerpNumber(
            self.activeTabHighlightY or activeTabTargetY,
            activeTabTargetY,
            SmoothFactor(18, dt)
        )
    end

    if math.abs((self.activeTabHighlightY or activeTabTargetY) - activeTabTargetY) >= 0.02 then
        shellAnimating = true
    else
        self.activeTabHighlightY = activeTabTargetY
    end

    for tabIndex = 1, #self.tabs do
        local hoverTarget = self.hoveredId == ("tab_" .. tostring(tabIndex)) and 1 or 0
        local activeTarget = self.selectedTab == tabIndex and 1 or 0

        local _, hoverMoving = self:AnimateValue(self.animationState.tabHover, tabIndex, hoverTarget, 18, dt, 0)
        local _, activeMoving = self:AnimateValue(self.animationState.tabActive, tabIndex, activeTarget, 18, dt, activeTarget)

        shellAnimating = shellAnimating or hoverMoving or activeMoving
    end

    for _, tabControls in ipairs(self.controls or {}) do
        for _, control in ipairs(tabControls) do
            local controlType = self:GetControlType(control)
            local controlId = self:GetControlId(control)
            local hoverTarget = self.hoveredId == controlId and 1 or 0
            local _, hoverMoving = self:AnimateValue(self.animationState.controlHover, controlId, hoverTarget, 16, dt, 0)

            tabAnimating = tabAnimating or hoverMoving

            if controlType == "dropdown_single" or controlType == "dropdown_multi" then
                local _, moving = self:AnimateValue(
                    self.animationState.dropdownOpen,
                    controlId,
                    self.expandedDropdown == controlId and 1 or 0,
                    18,
                    dt,
                    0
                )

                tabAnimating = tabAnimating or moving

            elseif controlType == "slider" then
                local percent = self:GetSliderPercent(control)
                local _, moving = self:AnimateValue(self.animationState.sliderFill, controlId, percent, 14, dt, percent)

                tabAnimating = tabAnimating or moving

            elseif controlType == "toggle" then
                local target = self:GetControlRawValue(control, false) and 1 or 0
                local _, moving = self:AnimateValue(self.animationState.toggleFill, controlId, target, 16, dt, target)

                tabAnimating = tabAnimating or moving

            elseif controlType == "checkbox" then
                local target = self:GetControlRawValue(control, false) and 1 or 0
                local _, moving = self:AnimateValue(self.animationState.checkboxFill, controlId, target, 16, dt, target)

                tabAnimating = tabAnimating or moving
            end
        end
    end

    local _, _, _, _, thumbTargetY = self:GetScrollbarMetrics()
    self.animatedScrollThumbY = LerpNumber(self.animatedScrollThumbY or thumbTargetY, thumbTargetY, SmoothFactor(16, dt))

    if math.abs((self.animatedScrollThumbY or thumbTargetY) - thumbTargetY) >= 0.02 then
        tabAnimating = true
    else
        self.animatedScrollThumbY = thumbTargetY
    end

    self.animationsActive = shellAnimating or tabAnimating

    if shellAnimating then
        self:MarkShellDirty()
    end

    if tabAnimating then
        self:MarkCurrentTabDirty()
    end
end

function UI:DrawCardFrame(bucket, x, y, w, h, outlineColor)
