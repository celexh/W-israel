function UI:ReadHTTPBody(response, transportName)
    if type(response) == "table" then
        local body = response.Body or response.body or response.Response or response.response or ""
        local status = tonumber(response.StatusCode or response.status_code or response.Status or response.status)
        local success = response.Success
        if success == nil then
            success = response.success
        end
        local statusMessage = response.StatusMessage or response.status_message or response.Message or response.message or ""

        self:DebugAI(
            "response",
            tostring(transportName or "http"),
            "status",
            tostring(status or "nil"),
            "success",
            tostring(success),
            "bodyChars",
            tostring(#tostring(body or ""))
        )
        self:DebugAIVerbose("response body", tostring(body or ""))

        if status and status >= 400 then
            error(tostring(transportName or "HTTP") .. " HTTP " .. tostring(status) .. ": " .. tostring(body):sub(1, 220))
        end
        if success == false then
            error(tostring(transportName or "HTTP") .. " request failed: " .. tostring(statusMessage ~= "" and statusMessage or body):sub(1, 220))
        end
        if tostring(body or "") == "" then
            error(tostring(transportName or "HTTP") .. " returned empty body")
        end
        return tostring(body or "")
    end

    local body = tostring(response or "")
    self:DebugAI("response", tostring(transportName or "http"), "rawChars", tostring(#body))
    self:DebugAIVerbose("response body", body)
    if body == "" then
        error(tostring(transportName or "HTTP") .. " returned empty body")
    end
    return body
end

function UI:TryHTTPTransport(transportName, callback)
    self:SetAIStage("transport try " .. tostring(transportName))
    self:DebugAI("transport try", transportName)

    local ok, response = pcall(function()
        self:SetAIStage("waiting response " .. tostring(transportName))
        return callback()
    end)

    if not ok then
        self:DebugAI("transport error", transportName, tostring(response))
        return nil, tostring(response)
    end

    local bodyOk, body = pcall(function()
        return self:ReadHTTPBody(response, transportName)
    end)

    if not bodyOk then
        self:DebugAI("transport error", transportName, tostring(body))
        return nil, tostring(body)
    end

    self:SetAIStage("response received")
    return body, nil
end

function UI:HttpPostBackend(url, payload, headers)
    headers = headers or {
        ["Content-Type"] = "application/json",
    }

    local lastError = nil
    local body, err = self:TryHTTPTransport("game:HttpPost", function()
        return game:HttpPost(url, payload, "application/json")
    end)
    if body then
        return body
    end
    lastError = err

    if HttpService and type(HttpService.PostAsync) == "function" then
        body, err = self:TryHTTPTransport("HttpService:PostAsync", function()
            return HttpService:PostAsync(url, payload, Enum.HttpContentType.ApplicationJson)
        end)
        if body then
            return body
        end
        lastError = err
    end

    local requesters = {
        {name = "request", fn = type(request) == "function" and request or nil},
        {name = "http_request", fn = type(http_request) == "function" and http_request or nil},
        {name = "syn.request", fn = type(syn) == "table" and type(syn.request) == "function" and syn.request or nil},
    }

    for _, transport in ipairs(requesters) do
        if transport.fn then
            body, err = self:TryHTTPTransport(transport.name, function()
                return transport.fn({
                    Url = url,
                    Method = "POST",
                    Headers = headers,
                    Body = payload,
                    Timeout = 15,
                })
            end)
            if body then
                return body
            end
            lastError = err
        end
    end

    error("all POST transports failed: " .. tostring(lastError or "no HTTP transport available"))
end

function UI:HttpGetBackend(url)
    local lastError = nil
    local body, err = self:TryHTTPTransport("game:HttpGet", function()
        return game:HttpGet(url)
    end)
    if body then
        return body
    end
    lastError = err

    if HttpService and type(HttpService.GetAsync) == "function" then
        body, err = self:TryHTTPTransport("HttpService:GetAsync", function()
            return HttpService:GetAsync(url)
        end)
        if body then
            return body
        end
        lastError = err
    end

    local requesters = {
        {name = "request GET", fn = type(request) == "function" and request or nil},
        {name = "http_request GET", fn = type(http_request) == "function" and http_request or nil},
        {name = "syn.request GET", fn = type(syn) == "table" and type(syn.request) == "function" and syn.request or nil},
    }

    for _, transport in ipairs(requesters) do
        if transport.fn then
            body, err = self:TryHTTPTransport(transport.name, function()
                return transport.fn({
                    Url = url,
                    Method = "GET",
                    Headers = {},
                    Timeout = 15,
                })
            end)
            if body then
                return body
            end
            lastError = err
        end
    end

    error("all GET transports failed: " .. tostring(lastError or "no HTTP transport available"))
end

function UI:PostAIBackend(url, userMessage)
    local username = LocalPlayer and LocalPlayer.Name or "Unknown"

    if self.aiDebug then
        print("[MatchaMind Request]", username, userMessage)
    end
    self:SetAIStage("post start")
    self:DebugAI("post start", "url", tostring(url), "messageChars", tostring(#tostring(userMessage or "")), "history", tostring(#(self.aiMessages or {})))

    local payload = self:BuildAIChatPayload(userMessage)
    self:DebugAIVerbose("payload", payload)

    local headers = {
        ["Content-Type"] = "application/json",
    }

    local responseBody = self:HttpPostBackend(url, payload, headers)

    local reply = responseBody
    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(responseBody)
    end)

    if decodeOk and type(decoded) == "table" then
        if decoded.error ~= nil then
            error("backend error: " .. tostring(decoded.error))
        end
        if decoded.reply == nil and decoded.text == nil and decoded.message == nil then
            error("backend JSON missing reply/text/message")
        end
        reply = decoded.reply or decoded.text or decoded.message or responseBody
        self:DebugAI("json decoded", "replyChars", tostring(#tostring(reply or "")))
    elseif not decodeOk then
        self:DebugAI("json decode fallback", tostring(decoded))
    end

    if self:TrimText(reply) == "" then
        error("backend returned empty reply")
    end

    return tostring(reply or "")
end

function UI:StartAIBackendJob(userMessage)
    self:SetAIStage("start job post")
    self:DebugAI("start job post", self:GetAIStartURL())

    local payload = self:BuildAIChatPayload(userMessage)
    self:DebugAIVerbose("start payload", payload)

    local responseBody = self:HttpPostBackend(self:GetAIStartURL(), payload, {
        ["Content-Type"] = "application/json",
    })

    self:DebugAI("start job response", tostring(responseBody):sub(1, 220))
    self:DebugAIVerbose("start job body", tostring(responseBody))

    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(responseBody)
    end)

    if not decodeOk or type(decoded) ~= "table" then
        error("chat/start returned invalid JSON: " .. tostring(decodeOk and responseBody or decoded):sub(1, 220))
    end

    if decoded.error ~= nil then
        error("chat/start error: " .. tostring(decoded.error))
    end

    local directReply = decoded.reply or decoded.text or decoded.message
    if directReply ~= nil then
        return {
            done = true,
            reply = tostring(directReply),
        }
    end

    local jobId = decoded.jobId or decoded.job_id or decoded.id
    if jobId ~= nil and tostring(jobId) ~= "" then
        self:DebugAI("job id", tostring(jobId))
        return {
            done = false,
            jobId = tostring(jobId),
        }
    end

    error("chat/start missing jobId or reply")
end

function UI:ScheduleAIJobPoll(jobId, requestSerial)
    if self.aiRequestSerial ~= requestSerial or not self.aiIsSending then
        return false
    end

    self.aiActiveJobId = tostring(jobId)
    self.aiPollingStartedAt = self.aiPollingStartedAt or tick()
    self.aiNextPollAt = tick()
    self.aiPollInFlight = false
    self:SetAIStage("poll waiting")
    self:DebugAI("poll armed", tostring(jobId), "every", tostring(self.aiPollInterval or 1))
    self:MarkCurrentTabDirty()
    return true
end

function UI:PollAIJob(jobId, requestSerial)
    if self.aiRequestSerial ~= requestSerial or not self.aiIsSending then
        return
    end

    local timeout = tonumber(self.aiPollTimeout) or 45
    if self.aiPollingStartedAt and (tick() - self.aiPollingStartedAt) >= timeout then
        self:FailAIRequest(requestSerial, "AI job timed out.")
        return
    end

    self.aiLastPollAt = tick()
    self:SetAIStage("poll GET result")
    self:DebugAI("poll GET result", tostring(jobId))

    local responseBody = self:HttpGetBackend(self:GetAIResultURL(jobId))
    self:DebugAIVerbose("poll body", tostring(responseBody))

    local decodeOk, decoded = pcall(function()
        return HttpService:JSONDecode(responseBody)
    end)

    if not decodeOk or type(decoded) ~= "table" then
        error("chat/result returned invalid JSON: " .. tostring(decodeOk and responseBody or decoded):sub(1, 220))
    end

    if decoded.ok == false then
        error(tostring(decoded.error or "chat/result returned ok=false"))
    end

    local status = tostring(decoded.status or "")
    if status == "pending" or decoded.pending == true or decoded.done == false then
        self:SetAIStage("poll pending")
        self:DebugAI("poll pending", tostring(jobId))
        self.aiNextPollAt = tick() + (tonumber(self.aiPollInterval) or 1)
        self:MarkCurrentTabDirty()
        return
    end

    local reply = decoded.reply or decoded.text or decoded.message
    if status == "done" or decoded.done == true or reply ~= nil then
        if reply == nil then
            error("chat/result done without reply")
        end
        self:SetAIStage("poll done")
        self:DebugAI("poll done", tostring(jobId), "chars", tostring(#tostring(reply)))
        self:CompleteAIRequest(requestSerial, tostring(reply))
        return
    end

    error("chat/result missing pending/done status")
end

function UI:UpdateAIPolling()
    if not self.aiIsSending or not self.aiActiveJobId then
        return
    end

    if self.aiPollInFlight then
        return
    end

    local now = tick()
    local timeout = tonumber(self.aiPollTimeout) or 45
    local startedAt = self.aiPollingStartedAt or self.aiRequestStartedAt or now

    if (now - startedAt) >= timeout then
        self:FailAIRequest(self.aiRequestSerial, "AI job timed out.")
        return
    end

    if now < (self.aiNextPollAt or 0) then
        return
    end

    local jobId = self.aiActiveJobId
    local requestSerial = self.aiRequestSerial

    self.aiPollInFlight = true
    self.aiLastPollAt = now
    self.aiNextPollAt = now + (tonumber(self.aiPollInterval) or 1)
    self:SetAIStage("poll GET queued")
    self:DebugAI("poll tick", tostring(jobId))

    local spawned = self:SpawnAIThread(function()
        local ok, err = pcall(function()
            self:PollAIJob(jobId, requestSerial)
        end)

        self.aiPollInFlight = false

        if not ok then
            self:FailAIRequest(requestSerial, err)
        end
    end)

    if not spawned then
        self.aiPollInFlight = false
        self:FailAIRequest(requestSerial, "poll scheduler unavailable")
    end
end

function UI:ProbeAIBackend()
    if self.aiIsSending then
        self:AddAIMessage("assistant", "Probe skipped: another MatchaMind request is still pending.")
        return
    end

    self:AddAIMessage("assistant", "Running backend probe...")
    self.aiIsSending = true
    self.aiScrollToLatest = true
    self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
    self.aiRequestStartedAt = tick()
    self:SetAIStage("queued")
    local requestSerial = self.aiRequestSerial

    local spawned = self:SpawnAIThread(function()
        self:SetAIStage("thread started")
        self:DebugAI("thread started", "probe", "serial", tostring(requestSerial))

        local results = {}

        self:SetAIStage("GET health start")
        self:DebugAI("GET health start", MATCHAMIND_HEALTH_URL)
        local healthOk, healthBody = pcall(function()
            return self:HttpGetBackend(MATCHAMIND_HEALTH_URL)
        end)

        if healthOk then
            self:DebugAI("GET health response", tostring(healthBody):sub(1, 220))
            table.insert(results, "GET /api/health OK: " .. tostring(healthBody):sub(1, 180))
        else
            self:DebugAI("GET health error", tostring(healthBody))
            table.insert(results, "GET /api/health failed: " .. tostring(healthBody):sub(1, 180))
        end

        self:SetAIStage("POST echo start")
        self:DebugAI("POST echo start", MATCHAMIND_ECHO_URL)
        local echoPayload = self:BuildAIProbePayload()
        self:DebugAIVerbose("echo payload", echoPayload)
        local echoOk, echoBody = pcall(function()
            return self:HttpPostBackend(MATCHAMIND_ECHO_URL, echoPayload, {
                ["Content-Type"] = "application/json",
            })
        end)

        if echoOk then
            self:DebugAI("POST echo response", tostring(echoBody):sub(1, 220))
            table.insert(results, "POST /debug/echo OK: " .. tostring(echoBody):sub(1, 180))
        else
            self:DebugAI("POST echo error", tostring(echoBody))
            table.insert(results, "POST /debug/echo failed: " .. tostring(echoBody):sub(1, 180))
        end

        self:SetAIStage("POST chat/start probe")
        self:DebugAI("POST chat/start probe", self:GetAIStartURL())
        local startPayload = self:BuildAIProbePayload()
        self:DebugAIVerbose("chat/start probe payload", startPayload)
        local startOk, startBody = pcall(function()
            return self:HttpPostBackend(self:GetAIStartURL(), startPayload, {
                ["Content-Type"] = "application/json",
            })
        end)

        if startOk then
            self:DebugAI("POST chat/start response", tostring(startBody):sub(1, 220))
            table.insert(results, "POST /chat/start OK: " .. tostring(startBody):sub(1, 180))

            local decodeOk, decoded = pcall(function()
                return HttpService:JSONDecode(startBody)
            end)

            if decodeOk and type(decoded) == "table" then
                local jobId = decoded.jobId or decoded.job_id or decoded.id
                if jobId then
                    local resultUrl = self:GetAIResultURL(jobId)
                    self:SetAIStage("GET chat/result probe")
                    self:DebugAI("GET chat/result probe", resultUrl)
                    local resultOk, resultBody = pcall(function()
                        return self:HttpGetBackend(resultUrl)
                    end)

                    if resultOk then
                        self:DebugAI("GET chat/result response", tostring(resultBody):sub(1, 220))
                        table.insert(results, "GET /chat/result OK: " .. tostring(resultBody):sub(1, 180))
                    else
                        self:DebugAI("GET chat/result error", tostring(resultBody))
                        table.insert(results, "GET /chat/result failed: " .. tostring(resultBody):sub(1, 180))
                    end
                end
            end
        else
            self:DebugAI("POST chat/start error", tostring(startBody))
            table.insert(results, "POST /chat/start failed: " .. tostring(startBody):sub(1, 180))
        end

        self:CompleteAIRequest(requestSerial, "Backend probe results: " .. table.concat(results, " | "))
    end)

    if not spawned then
        self.aiIsSending = false
        self.aiRequestStartedAt = nil
        self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
        self:SetAIStage("idle")
        self:DebugAI("spawn failed", "probe")
        self:AddAIMessage("assistant", self:FormatAIError("probe async scheduler unavailable"))
        self:MarkCurrentTabDirty()
    end
end

function UI:SendAIMessage()
    if self.aiIsSending then
        return
    end

    local inputControl = self:GetAIInputControl()
    local userMessage = self:TrimText(self:GetControlRawValue(inputControl, ""))
    if userMessage == "" then
        return
    end

    self:SetControlRawValue(inputControl, "")
    self:AddAIMessage("user", userMessage)
    self.aiIsSending = true
    self.aiScrollToLatest = true
    self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
    self.aiRequestStartedAt = tick()
    self:SetAIStage("queued")
    local requestSerial = self.aiRequestSerial
    self:DebugAI("send", "serial", tostring(requestSerial), "backend", tostring(self:GetAIBackendURL()))
    self:MarkCurrentTabDirty()

    local backendUrl = self:GetAIBackendURL()

    local spawned = self:SpawnAIThread(function()
        self:SetAIStage("thread started")
        self:DebugAI("thread started", "serial", tostring(requestSerial))

        local ok, result = pcall(function()
            if self.aiUsePolling then
                return self:StartAIBackendJob(userMessage)
            end

            return {
                done = true,
                reply = self:PostAIBackend(backendUrl, userMessage),
            }
        end)

        if ok then
            if type(result) == "table" and result.done == true then
                self:CompleteAIRequest(requestSerial, result.reply or "")
            elseif type(result) == "table" and result.jobId then
                self.aiActiveJobId = tostring(result.jobId)
                self.aiPollingStartedAt = tick()
                self.aiLastPollAt = 0
                self.aiPollInFlight = false
                self.aiNextPollAt = tick()
                if not self:ScheduleAIJobPoll(result.jobId, requestSerial) then
                    self:FailAIRequest(requestSerial, "poll scheduler unavailable")
                end
            else
                self:FailAIRequest(requestSerial, "chat/start returned unexpected result")
            end
        else
            if self.aiAllowDirectFallback == true then
                self:DebugAI("start failed, direct fallback", tostring(result))
                local directOk, directResult = pcall(function()
                    return self:PostAIBackend(backendUrl, userMessage)
                end)
                if directOk then
                    self:CompleteAIRequest(requestSerial, directResult or "")
                else
                    self:FailAIRequest(requestSerial, directResult)
                end
            else
                self:FailAIRequest(requestSerial, result)
            end
        end
    end)

    if not spawned then
        self.aiIsSending = false
        self.aiRequestStartedAt = nil
        self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
        self:SetAIStage("idle")
        self:DebugAI("spawn failed")
        self:AddAIMessage("assistant", self:FormatAIError("async scheduler unavailable"))
        self:MarkCurrentTabDirty()
    end
end

function UI:SetStatValue(controlId, value)
    local control = self:GetControl(1, controlId)
    local nextValue = tostring(value or "")
    if control and self:GetControlRawValue(control, "") ~= nextValue then
        self:SetControlRawValue(control, nextValue)
        self:MarkTabDirty(1)
    end
end

function UI:FormatDuration(seconds)
    local total = math.max(0, math.floor(tonumber(seconds) or 0))
    local hours = math.floor(total / 3600)
    local minutes = math.floor((total % 3600) / 60)
    local secs = total % 60

    if hours > 0 then
        return string.format("%dh %dm %ds", hours, minutes, secs)
    end

    if minutes > 0 then
        return string.format("%dm %ds", minutes, secs)
    end

    return string.format("%ds", secs)
end

function UI:RefreshHomeStats(force)
    if not force and not self.liveHomeStats then
        return
    end

    local now = tick()
    if not force and self.selectedTab ~= 1 then
        return
    end

    if not force and (now - (self.lastHomeStatRefresh or 0)) < 1 then
        return
    end

    self.lastHomeStatRefresh = now
    self:SetStatValue("uptime_stat", self:FormatDuration(now - (self.launchTick or now)))
    self:SetStatValue("profile_stat", LocalPlayer and LocalPlayer.Name or "Unknown")
    self:SetStatValue("game_stat", tostring(game and game.PlaceId or 0))
    if self.lastConfigSaveTick then
        self:SetStatValue("last_save_stat", self:FormatDuration(now - self.lastConfigSaveTick) .. " ago")
    else
        self:SetStatValue("last_save_stat", "Never")
    end
end

