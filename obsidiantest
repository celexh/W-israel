    self:CreateSquare(bucket, x, y, w, h, outlineColor or Theme.border, 1, false, 1)
    self:CreateLine(bucket, x + 1, y + 1, x + w - 2, y + 1, Theme.topHighlight, 0.42, 1)
    self:CreateLine(bucket, x + 1, y + 2, x + w - 2, y + 2, Theme.cardInner, 0.2, 1)
end

function UI:RegisterHitbox(id, x, y, w, h, callback, priority)
    table.insert(self.hitboxes, {
        id = id,
        x = x,
        y = y,
        w = w,
        h = h,
        callback = callback,
        priority = priority or 0,
    })
end

function UI:IsPointInRect(point, x, y, w, h)
    return point.X >= x and point.X <= (x + w) and point.Y >= y and point.Y <= (y + h)
end

function UI:IsPointInMainWindow(point)
    local wx, wyBase = self:GetRenderWindowPosition()
    local wy = wyBase + self:GetAnimatedWindowYOffset()
    return self:IsPointInRect(point, wx, wy, self.window.width, self.window.height)
end

function UI:GetLoadingBounds()
    local showSidebar = self.loadingShowSidebar == true

    local contentW = tonumber(self.loadingContentWidth) or 450
    local sidebarW = tonumber(self.loadingSidebarWidth) or 250
    local windowW = tonumber(self.loadingWindowWidth) or 450

    local loadW = showSidebar and (contentW + sidebarW) or windowW
    local loadH = tonumber(self.loadingWindowHeight) or 275

    if self.loadingAutoResizeHeight then
        local innerContentHeight = 64 + 12 + 18 + 12 + 14 + 12 + 15
        local requiredContentHeight = 49 + 48 + innerContentHeight

        local sidebarItems = self.loadingSidebarItems or {}
        local requiredSidebarHeight = 49 + 18 + 18 + (#sidebarItems * 32) + 20

        loadH = math.max(self.loadingBaseWindowHeight or 275, requiredContentHeight, requiredSidebarHeight)
        self.loadingWindowHeight = loadH
    end

    local viewport = self:GetViewportSize()
    local loadX = math.floor((viewport.X - loadW) * 0.5)
    local loadY = math.floor((viewport.Y - loadH) * 0.5)

    return loadX, loadY, loadW, loadH, contentW, sidebarW
end

function UI:IsPointInLoadingWindow(point)
    local loadX, loadY, loadW, loadH = self:GetLoadingBounds()
    return self:IsPointInRect(point, loadX, loadY, loadW, loadH)
end

function UI:GetMouseLocation()
    local ok, pos = pcall(function()
        return UserInputService:GetMouseLocation()
    end)
    if ok and pos then
        return pos
    end

    if LocalMouse then
        return Vector2.new(LocalMouse.X or 0, LocalMouse.Y or 0)
    end

    return Vector2.new(0, 0)
end

function UI:TrimText(text)
    return tostring(text or ""):match("^%s*(.-)%s*$")
end

function UI:SetSearchText(text)
    text = tostring(text or "")

    if self.searchText == text then
        return
    end

    self.searchText = text
    self:UpdateSearch()
end

function UI:ClearSearch()
    self:SetSearchText("")
end

function UI:ControlMatchesSearch(control)
    local query = self:TrimText(self.searchText):lower()

    if query == "" then
        return true
    end

    if not control then
        return false
    end

    local haystack = table.concat({
        tostring(control.id or control.Idx or control.idx or ""),
        tostring(control.label or ""),
        tostring(control.Text or control.text or ""),
        tostring(control.description or ""),
        tostring(control.type or control.Type or ""),
        tostring(self:GetControlRawValue(control, "")),
    }, " "):lower()

    return string.find(haystack, query, 1, true) ~= nil
end

function UI:TabHasSearchMatch(tabIndex)
    local tabControls = self.controls[tabIndex] or {}

    for _, control in ipairs(tabControls) do
        if self:ControlMatchesSearch(control) then
            return true
        end
    end

    return false
end

function UI:GetFirstSearchMatchTab()
    for tabIndex, _ in ipairs(self.controls or {}) do
        if self:TabHasSearchMatch(tabIndex) then
            return tabIndex
        end
    end

    return nil
end

function UI:UpdateSearch()
    local query = self:TrimText(self.searchText)
    self.searching = query ~= ""
    self.scroll.offset = 0

    if not self.searching then
        self.lastSearchTab = nil
        self:MarkShellDirty()

        for tabIndex = 1, #self.controls do
            self:MarkTabDirty(tabIndex)
        end

        return
    end

    if self.globalSearch then
        local activeHasMatch = self:TabHasSearchMatch(self.selectedTab)
        local firstMatchTab = self:GetFirstSearchMatchTab()

        if firstMatchTab and not activeHasMatch then
            self.selectedTab = firstMatchTab
            self.expandedDropdown = nil
            self.contentAlpha = 0
            self.contentOffset = 6
        end

        self.lastSearchTab = nil
    else
        self.lastSearchTab = self.selectedTab
    end

    self:UpdateScrollLimit()
    self:MarkShellDirty()

    for tabIndex = 1, #self.controls do
        self:MarkTabDirty(tabIndex)
    end
end

function UI:GetSearchBounds()
    local wx, wyBase = self:GetRenderWindowPosition()
    local wy = wyBase + self:GetAnimatedWindowYOffset()
    local ww = self.window.width
    local sidebarW = self.window.sidebarWidth

    local searchX = wx + sidebarW + 12
    local searchY = wy + 9
    local searchRight = wx + ww - 14
    local searchW = searchRight - searchX
    local searchH = 34

    return searchX, searchY, searchW, searchH
end

function UI:IsPointInSearchBox(point)
    local x, y, w, h = self:GetSearchBounds()
    return self:IsPointInRect(point, x, y, w, h)
end

function UI:SetRobloxInputEnabled(enabled)
    if type(setrobloxinput) ~= "function" then
        return
    end

    local shouldDisable = enabled ~= true
    if self.robloxInputDisabled == shouldDisable then
        return
    end

    local ok = pcall(setrobloxinput, enabled == true)
    if ok then
        self.robloxInputDisabled = shouldDisable
    end
end

function UI:UpdateRobloxInputCapture()
    local shouldCapture = self.uiVisible == true
        and self.isBooting ~= true
        and (
            self.searchFocused == true
            or self.activeTextInput ~= nil
            or self.activeDropdownSearch ~= nil
        )

    self:SetRobloxInputEnabled(not shouldCapture)
end

function UI:FocusSearch()
    if self.searchFocused or self.activeTextInput or self.activeDropdownSearch or self.activeKeybind then
        return
    end

    self.activeTextInput = nil
    self.activeDropdownSearch = nil
    self.activeKeybind = nil
    self.expandedDropdown = nil
    self.expandedColorPicker = nil
    self.searchFocused = true
    self.searchCursor = true
    self.searchCursorTick = tick()
    self:ZeroSearchKeys()
    self:UpdateRobloxInputCapture()
    self:MarkShellDirty()
end

function UI:ZeroSearchKeys()
    for key in pairs(searchPrevKeys) do
        searchPrevKeys[key] = false
    end
end

function UI:BlurSearch()
    if not self.searchFocused then
        return
    end

    self.searchFocused = false
    self:ZeroSearchKeys()
    self:UpdateRobloxInputCapture()
    self:MarkShellDirty()
end

function UI:GetFocusedTextControl()
    if not self.activeTextInput then
        return nil, nil
    end

    local control, tabIndex = self:GetControlById(self.activeTextInput)
    if not control or self:IsControlDisabled(control) then
        self.activeTextInput = nil
        self:UpdateRobloxInputCapture()
        return nil, nil
    end

    local controlType = self:GetControlType(control)
    if controlType ~= "input" and controlType ~= "textbox" then
        self.activeTextInput = nil
        self:UpdateRobloxInputCapture()
        return nil, nil
    end

    return control, tabIndex
end

function UI:BlurActiveTextInput()
    if not self.activeTextInput then
        return
    end

    self.activeTextInput = nil
    self:ZeroSearchKeys()
    self:UpdateRobloxInputCapture()
    self:MarkCurrentTabDirty()
end

function UI:SetFocusedTextValue(text, control, tabIndex)
    control = control or self:GetFocusedTextControl()
    if not control then
        return
    end

    text = tostring(text or "")

    local maxLength = control.maxLength or control.MaxLength
    if maxLength and #text > maxLength then
        text = text:sub(1, maxLength)
    end

    if (control.numeric or control.Numeric) and text ~= "" and not tonumber(text) then
        return
    end

    if self:GetControlRawValue(control, "") == text then
        return
    end

    self:SetControlRawValue(control, text)
    self:RunAction(control, text)
    self:MarkTabDirty(tabIndex or self.selectedTab)
    if self:GetControlId(control) ~= "ai_prompt_input" then
        self:SaveConfig(false)
    end
end

function UI:RegisterSearchHitbox()
    local searchX, searchY, searchW, searchH = self:GetSearchBounds()

    self:RegisterHitbox("search_box", searchX, searchY, searchW, searchH, function()
        self:FocusSearch()
    end, 5)
end

function UI:PollSearchKeys()
    local focusedControl, focusedTab = self:GetFocusedTextControl()
    local dropdownSearchId = self.activeDropdownSearch
    local dropdownControl = nil
    if dropdownSearchId then
        dropdownControl = self:GetControlById(dropdownSearchId)
        if not dropdownControl or self.expandedDropdown ~= dropdownSearchId then
            self.activeDropdownSearch = nil
            dropdownControl = nil
        end
    end

    local typingSearch = self.searchFocused == true
    local typingInput = focusedControl ~= nil
    local typingDropdown = dropdownControl ~= nil

    if not typingSearch and not typingInput and not typingDropdown then
        self:UpdateRobloxInputCapture()
        return
    end

    self:UpdateRobloxInputCapture()

    if type(iskeypressed) ~= "function" then
        return
    end

    local function getFocusedText()
        if typingSearch then
            return tostring(self.searchText or "")
        elseif typingDropdown then
            return tostring(self.dropdownSearchText[dropdownSearchId] or "")
        end
        return tostring(self:GetControlRawValue(focusedControl, ""))
    end

    local function setFocusedText(text)
        if typingSearch then
            self:SetSearchText(text)
        elseif typingDropdown then
            self.dropdownSearchText[dropdownSearchId] = tostring(text or "")
            self:UpdateScrollLimit()
            self:MarkCurrentTabDirty()
        else
            self:SetFocusedTextValue(text, focusedControl, focusedTab)
        end
    end

    local now = tick()
    if now - (self.searchCursorTick or 0) > 0.53 then
        self.searchCursor = not self.searchCursor
        self.searchCursorTick = now
        if typingSearch then
            self:MarkShellDirty()
        end
        if typingInput then
            self:MarkCurrentTabDirty()
        end
        if typingDropdown then
            self:MarkCurrentTabDirty()
        end
    end

    local shift = false
    pcall(function()
        shift = iskeypressed(VK.SHIFT) == true
    end)

    local escDown = false
    pcall(function()
        escDown = iskeypressed(VK.ESCAPE) == true
    end)

    if escDown and not searchPrevKeys[VK.ESCAPE] then
        if typingSearch then
            self:BlurSearch()
        end
        if typingInput then
            self:BlurActiveTextInput()
        end
        if typingDropdown then
            self.activeDropdownSearch = nil
            self.expandedDropdown = nil
            self:UpdateScrollLimit()
            self:MarkCurrentTabDirty()
        end
    end
    searchPrevKeys[VK.ESCAPE] = escDown

    local enterDown = false
    pcall(function()
        enterDown = iskeypressed(VK.RETURN) == true
    end)

    if enterDown and not searchPrevKeys[VK.RETURN] then
        if typingSearch then
            self:BlurSearch()
        end
        if typingInput then
            if self:GetControlId(focusedControl) == "ai_prompt_input" then
                self:SendAIMessage()
            else
                self:BlurActiveTextInput()
            end
        end
        if typingDropdown then
            self.activeDropdownSearch = nil
            self.expandedDropdown = nil
            self:UpdateScrollLimit()
            self:MarkCurrentTabDirty()
        end
    end
    searchPrevKeys[VK.RETURN] = enterDown

    local backDown = false
    pcall(function()
        backDown = iskeypressed(VK.BACK) == true
    end)

    now = tick()

    if backDown then
        if not searchPrevKeys[VK.BACK] then
            self.searchBackspaceStartedAt = now
            self.searchBackspaceNextAt = now + (self.searchBackspaceDelay or 0.35)

            local text = getFocusedText()
            if #text > 0 then
                setFocusedText(text:sub(1, -2))
            end

        elseif self.searchBackspaceNextAt and now >= self.searchBackspaceNextAt then
            local text = getFocusedText()
            if #text > 0 then
                setFocusedText(text:sub(1, -2))
            end

            self.searchBackspaceNextAt = now + (self.searchBackspaceRate or 0.045)
        end
    else
        self.searchBackspaceStartedAt = nil
        self.searchBackspaceNextAt = nil
    end

    searchPrevKeys[VK.BACK] = backDown

    local delDown = false
    pcall(function()
        delDown = iskeypressed(VK.DELETE) == true
    end)

    if delDown and not searchPrevKeys[VK.DELETE] then
        setFocusedText("")
    end
    searchPrevKeys[VK.DELETE] = delDown

    for vk, chars in pairs(VKCHARS) do
        local down = false
        pcall(function()
            down = iskeypressed(vk) == true
        end)

        if down and not searchPrevKeys[vk] then
            local char = shift and chars[2] or chars[1]
            setFocusedText(getFocusedText() .. char)
        end

        searchPrevKeys[vk] = down
    end
end

function UI:PollKeybindCapture()
    if not self.activeKeybind or self.searchFocused or self.activeTextInput or self.activeDropdownSearch then
        return
    end

    if type(iskeypressed) ~= "function" then
        return
    end

    local control = self:GetControlById(self.activeKeybind)
    if not control or self:IsControlDisabled(control) then
        self.activeKeybind = nil
        self:MarkCurrentTabDirty()
        return
    end

    for _, keyCode in ipairs(VK_CAPTURE_ORDER) do
        local down = false
        pcall(function()
            down = iskeypressed(keyCode) == true
        end)

        if down and not keybindPrevKeys[keyCode] then
            if keyCode == VK.ESCAPE then
                self.activeKeybind = nil
                self:MarkCurrentTabDirty()
            elseif keyCode == VK.BACK or keyCode == VK.DELETE then
                self:SetControlRawValue(control, "None")
                self.activeKeybind = nil
                self:RunAction(control, "None")
                self:MarkCurrentTabDirty()
                self:SaveConfig(false)
            else
                local keyName = VK_NAMES[keyCode] or tostring(keyCode)
                self:SetControlRawValue(control, keyName)
                self.activeKeybind = nil
                self:RunAction(control, keyName)
                self:MarkCurrentTabDirty()
                self:SaveConfig(false)
            end
        end

        keybindPrevKeys[keyCode] = down
    end
end

function UI:IsMousePressed()
    local ok, pressed = pcall(function()
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    end)
    if ok then
        return pressed == true
    end

    if type(ismouse1pressed) == "function" then
        local pressOk, result = pcall(ismouse1pressed)
        if pressOk then
            return result == true
        end
    end

    return false
end

function UI:HasActiveInteraction()
    return self.draggingResize == true
        or self.draggingWindow == true
        or self.draggingSlider == true
        or self.draggingScroll == true
        or self.draggingAIChatScroll == true
        or self.searchFocused == true
        or self.activeTextInput ~= nil
        or self.activeDropdownSearch ~= nil
        or self.activeKeybind ~= nil
        or self.expandedDropdown ~= nil
        or self.expandedColorPicker ~= nil
end

function UI:PollFrameInputChanged()
    local mousePos = self:GetMouseLocation()
    local mouseDown = self:IsMousePressed()
    local mouseX = math.floor((mousePos.X or 0) + 0.5)
    local mouseY = math.floor((mousePos.Y or 0) + 0.5)
    local changed = self.lastFrameMouseX ~= mouseX
        or self.lastFrameMouseY ~= mouseY
        or self.lastFrameMouseDown ~= mouseDown

    self.lastFrameMouseX = mouseX
    self.lastFrameMouseY = mouseY
    self.lastFrameMouseDown = mouseDown

    return changed, mousePos, mouseDown
end

function UI:GetActiveControls()
    local tabControls = self.controls[self.selectedTab] or {}

    if not self.searching then
        return tabControls
    end

    local filtered = {}

    for _, control in ipairs(tabControls) do
        if self:ControlMatchesSearch(control) then
            table.insert(filtered, control)
        end
    end

    return filtered
end

function UI:GetControl(tabIndex, controlId)
    local tabControls = self.controls[tabIndex] or {}
    for _, control in ipairs(tabControls) do
        if control.id == controlId or control.Idx == controlId or control.idx == controlId or control._drawId == controlId then
            return control
        end
    end
    return nil
end

function UI:GetAIInputControl()
    return self:GetControl(self.aiTabIndex or 4, "ai_prompt_input")
end

function UI:GetAIBackendURL()
    return MATCHAMIND_BACKEND_URL
end

function UI:GetAIStartURL()
    return MATCHAMIND_START_URL
end

function UI:GetAIResultURL(jobId)
    return MATCHAMIND_RESULT_BASE_URL .. tostring(jobId or "")
end

function UI:FocusTextControl(controlId)
    self:BlurSearch()
    self:BlurActiveTextInput()
    self.activeDropdownSearch = nil
    self.activeKeybind = nil
    self.expandedDropdown = nil
    self.expandedColorPicker = nil
    self.activeTextInput = controlId
    self.searchCursor = true
    self.searchCursorTick = tick()
    self:ZeroSearchKeys()
    self:UpdateRobloxInputCapture()
    self:MarkCurrentTabDirty()
end

function UI:SetAIChatScroll(offset)
    local maxOffset = math.max(0, tonumber(self.aiChatScrollMax) or 0)
    local nextOffset = math.clamp(math.floor(tonumber(offset) or 0), 0, maxOffset)
    if self.aiChatScroll == nextOffset then
        return false
    end

    self.aiChatScroll = nextOffset
    self.aiScrollToLatest = nextOffset >= (maxOffset - 1)
    self:MarkCurrentTabDirty()
    return true
end

function UI:ScrollAIChat(delta)
    return self:SetAIChatScroll((self.aiChatScroll or 0) + (tonumber(delta) or 0))
end

function UI:AddAIMessage(role, text)
    self.aiMessages = self.aiMessages or {}
    table.insert(self.aiMessages, {
        role = tostring(role or "assistant"),
        text = tostring(text or ""),
    })

    while #self.aiMessages > 40 do
        table.remove(self.aiMessages, 1)
    end

    self.aiScrollToLatest = true
    self:MarkCurrentTabDirty()
end

function UI:ClearAIChat()
    self.aiMessages = {}
    self.aiChatScroll = 0
    self.aiChatScrollMax = 0
    self.aiChatContentHeight = 0
    self.aiChatViewportHeight = 0
    self.aiScrollToLatest = true
    self.aiIsSending = false
    self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
    self.aiRequestStartedAt = nil
    self.aiActiveJobId = nil
    self.aiPollingStartedAt = nil
    self.aiLastPollAt = 0
    self.aiPollInFlight = false
    self.aiNextPollAt = 0
    self:SetAIStage("idle")

    local inputControl = self:GetAIInputControl()
    self:SetControlRawValue(inputControl, "")
    self:MarkCurrentTabDirty()
end

function UI:DebugAI(event, ...)
    if not self.aiDebug then
        return
    end

    print("[MatchaMind Debug]", tostring(event), ...)
end

function UI:DebugAIVerbose(event, ...)
    if not self.aiDebug or not self.aiDebugVerbose then
        return
    end

    print("[MatchaMind Verbose]", tostring(event), ...)
end

function UI:SetAIStage(stage)
    self.aiLastStage = tostring(stage or "idle")
end

function UI:FormatAIError(message)
    local text = self:TrimText(tostring(message or "unknown error"))
    if text == "" then
        text = "unknown error"
    end

    if #text > 420 then
        text = text:sub(1, 420) .. "..."
    end

    if text:sub(1, 15) == "Request failed:" then
        return text
    end

    return "Request failed: " .. text
end

function UI:CompleteAIRequest(requestSerial, reply)
    if self.aiRequestSerial ~= requestSerial then
        self:DebugAI("late response ignored", tostring(requestSerial), "current", tostring(self.aiRequestSerial))
        return false
    end

    self.aiIsSending = false
    self.aiRequestStartedAt = nil
    self.aiActiveJobId = nil
    self.aiPollingStartedAt = nil
    self.aiLastPollAt = 0
    self.aiPollInFlight = false
    self.aiNextPollAt = 0
    self:DebugAI("complete", "serial", tostring(requestSerial), "chars", tostring(#tostring(reply or "")))
    self:AddAIMessage("assistant", reply or "")
    self:SetAIStage("idle")
    self:MarkCurrentTabDirty()
    return true
end

function UI:FailAIRequest(requestSerial, message)
    self:DebugAI("error", tostring(message or "unknown error"))
    return self:CompleteAIRequest(requestSerial, self:FormatAIError(message))
end

function UI:UpdateAIRequestTimeout()
    if not self.aiIsSending then
        return
    end

    local startedAt = self.aiRequestStartedAt
    if not startedAt then
        return
    end

    local timeout = self.aiUsePolling and (tonumber(self.aiPollTimeout) or 45) or (tonumber(self.aiRequestTimeout) or 30)
    if (tick() - startedAt) < timeout then
        return
    end

    local lastStage = self.aiLastStage or "unknown"
    local jobId = self.aiActiveJobId or "none"
    self.aiIsSending = false
    self.aiRequestStartedAt = nil
    self.aiActiveJobId = nil
    self.aiPollingStartedAt = nil
    self.aiLastPollAt = 0
    self.aiPollInFlight = false
    self.aiNextPollAt = 0
    self.aiRequestSerial = (self.aiRequestSerial or 0) + 1
    self:DebugAI("timeout", "after", tostring(timeout), "seconds", "stage", tostring(lastStage), "job", tostring(jobId))
    self:AddAIMessage("assistant", self:FormatAIError("backend did not respond after " .. tostring(timeout) .. "s. Last stage: " .. tostring(lastStage) .. ". Job: " .. tostring(jobId)))
    self:SetAIStage("idle")
    self:MarkCurrentTabDirty()
end

function UI:SpawnAIThread(callback)
    if type(callback) ~= "function" then
        return false
    end

    if task and type(task.spawn) == "function" then
        self:DebugAI("scheduler", "task.spawn")
        local ok = pcall(function()
            task.spawn(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "task.spawn")
    end

    if type(spawn) == "function" then
        self:DebugAI("scheduler", "spawn")
        local ok = pcall(function()
            spawn(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "spawn")
    end

    if type(delay) == "function" then
        self:DebugAI("scheduler", "delay")
        local ok = pcall(function()
            delay(0, callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "delay")
    end

    if task and type(task.defer) == "function" then
        self:DebugAI("scheduler", "task.defer")
        local ok = pcall(function()
            task.defer(callback)
        end)
        if ok then
            return true
        end
        self:DebugAI("scheduler error", "task.defer")
    end

    return false
end

function UI:WaitAI(seconds)
    if task and type(task.wait) == "function" then
        task.wait(seconds or 0)
    elseif type(wait) == "function" then
        wait(seconds or 0)
    end
end

